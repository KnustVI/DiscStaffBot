<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | <%= bot.user.username %></title>
    
    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&family=Bebas+Neue&display=swap" rel="stylesheet">

    <!-- Tailwind CDN (Obrigatório para o visual do Builder funcionar) -->
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'titan-dark': '#1F1D20',
                        'titan-cream': '#F8DCC0',
                        'titan-accent': '#803E30',
                    }
                }
            }
        }
    </script>

    <style>
        html, body { margin: 0; padding: 0; overflow-x: hidden; max-width: 100%; }
        .guild-icon-img { width: 100%; height: 100%; object-fit: cover; border-radius: inherit; }

        /* Componente .btn-primary (Figma node 250-59) - mesma definicao de web/public/css/style.css,
           duplicada aqui pq esta pagina usa um <style> proprio em vez do stylesheet compartilhado. */
        .btn-primary {
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 5px 20px;
            gap: 10px;
            min-width: 232px;
            height: 39px;
            background: #2A2A2A;
            border: 1px solid #803E30;
            border-radius: 15px;
            box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.5), -5px -5px 10px rgba(0, 0, 0, 0.7);
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            font-size: 20px;
            line-height: 30px;
            color: #F8DCC0;
            text-decoration: none;
            cursor: pointer;
            transition: background 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        }
        .btn-primary-icon {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: currentColor;
            flex: none;
        }
        .btn-primary:hover {
            background: #803E30;
            border-color: #F8DCC0;
            box-shadow: -5px -5px 10px rgba(0, 0, 0, 0.5), 5px 5px 10px rgba(0, 0, 0, 0.5),
                        10px 10px 20px rgba(0, 0, 0, 0.5), -10px -10px 20px rgba(0, 0, 0, 0.5);
        }
        .btn-primary:active {
            background: #4B2427;
            border-color: #803E30;
            box-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5), -1px -1px 2px rgba(0, 0, 0, 0.5),
                        inset 0px 8px 7.8px rgba(0, 0, 0, 0.59);
        }

        /* Barra de navegação (Figma: "ButtonMobile", 5 botões — HOME/PREMIUM/
           PATCH UPDATES/DOCUMENTATION/SUPPORT). Mesma familia visual do
           .btn-primary (fundo/borda/sombra), só menor e com peso de fonte leve. */
        .nav-btn {
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 5px 20px;
            gap: 10px;
            height: 30px;
            background: #2A2A2A;
            border: 1px solid #803E30;
            border-radius: 15px;
            box-shadow: 5px 5px 10px rgba(0, 0, 0, 0.5), -5px -5px 10px rgba(0, 0, 0, 0.7);
            font-family: 'Poppins', sans-serif;
            font-weight: 300;
            font-size: 14px;
            line-height: 21px;
            color: #F8DCC0;
            text-decoration: none;
            white-space: nowrap;
            transition: background 0.15s ease, border-color 0.15s ease;
        }
        .nav-btn:hover {
            background: #803E30;
            border-color: #F8DCC0;
        }
        .nav-btn.disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; }
        .nav-btn-icon {
            width: 12px;
            height: 12px;
            flex: none;
        }
    </style>
</head>
<body>

    <div class="min-h-screen w-full flex flex-col items-stretch p-4 sm:p-6 md:p-8"
         style="background: linear-gradient(180deg, #252326 0%, #1F1D20 54.34%, #131314 98.29%);">

        <!-- Navegação -->
        <nav class="w-full flex flex-wrap items-center justify-center" style="gap: clamp(10px, 2vw, 20px); padding: 10px 0 28px;">
            <a href="/" class="nav-btn">
                <svg class="nav-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/>
                    <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                </svg>
                <span>HOME</span>
            </a>
            <a href="#" class="nav-btn">
                <svg class="nav-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M6 3h12l4 6-10 13L2 9Z"/>
                    <path d="M11 3 8 9l4 13 4-13-3-6"/>
                    <path d="M2 9h20"/>
                </svg>
                <span>PREMIUM</span>
            </a>
            <a href="#" class="nav-btn disabled" aria-disabled="true" tabindex="-1">
                <svg class="nav-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 8v8"/>
                    <path d="M8.4 2.51a2 2 0 0 1 2.98-.02l9.152 9.129a2 2 0 0 1 .002 2.822l-9.15 9.161a2 2 0 0 1-2.822.005l-9.151-9.129a2 2 0 0 1-.002-2.822z"/>
                    <path d="M8 12h8"/>
                </svg>
                <span>UPDATES</span>
            </a>
            <a href="#" class="nav-btn disabled" aria-disabled="true" tabindex="-1">
                <svg class="nav-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="18" height="18" x="3" y="3" rx="2"/>
                    <path d="M7 8h10"/>
                    <path d="M7 12h10"/>
                    <path d="M7 16h10"/>
                </svg>
                <span>DOCUMENTAÇÃO</span>
            </a>
            <a href="https://discord.gg/fkD5FQktn6" target="_blank" rel="noopener" class="nav-btn">
                <svg class="nav-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
                </svg>
                <span>SUPPORT</span>
            </a>
        </nav>

        <div class="flex-1 flex flex-col items-center justify-center w-full" style="gap: clamp(28px, 5vw, 56px); padding: clamp(16px, 3vw, 32px) 0;">

            <!-- Seção Superior: Logo e Boas-vindas -->
            <div class="flex flex-col items-center w-full" style="gap: clamp(20px, 3vw, 32px);">
                <div class="flex items-center justify-center" style="width: clamp(170px, 25vw, 300px);">
                    <img src="/images/landing/titans-pass-logo.webp"
                         alt="Titan's Pass Logo" class="w-full h-auto object-contain" style="max-height: clamp(130px, 18vw, 210px);">
                </div>

                <div class="text-center px-4">
                    <p class="text-titan-cream leading-tight mb-1"
                       style="font-family: 'Tilt Warp', sans-serif; font-size: clamp(16px, 2.2vw, 26px);">
                        BEM VINDO AO DASHBOARD DO TITAN'S PASS
                    </p>
                    <p class="text-titan-cream"
                       style="font-family: 'Poppins', sans-serif; font-size: clamp(12px, 1.3vw, 16px);">
                        <% if (user) { %> Escolha o servidor que vai manejar <% } else { %> Entre para gerenciar seus servidores <% } %>
                    </p>
                </div>
            </div>

            <!-- Seção Inferior: Usuário + Servidores -->
            <div class="flex flex-col sm:flex-row items-center justify-center gap-8 md:gap-12 lg:gap-16 w-full max-w-4xl px-4">
                
                <% if (user) { %>
                    <!-- Perfil do Usuário Logado -->
                    <div class="flex flex-col items-center gap-2 shrink-0">
                        <div class="rounded-full bg-titan-dark flex items-center justify-center shrink-0 overflow-hidden"
                             style="width: clamp(64px, 7vw, 96px); height: clamp(64px, 7vw, 96px); border: 3px solid #803E30; box-shadow: 0 12px 18px 11px rgba(1, 2, 10, 0.45);">
                            <img src="<%= user.avatar ? `https://cdn.discordapp.com/avatars/${user.id}/${user.avatar}.png` : `https://cdn.discordapp.com/embed/avatars/${(user.id % 5)}.png` %>" 
                            onerror="this.src='https://discord.com/assets/f78426a064bc9dd24847519294b081dd.png'"
                            class="w-full h-full object-cover">
                        </div>
                        <div class="flex flex-col items-center justify-center w-full mt-1">
                            <span class="text-titan-cream text-center" style="font-family: 'Tilt Warp', sans-serif; font-size: clamp(16px, 2vw, 24px);">
                                <%# Tenta puxar o apelido (nickname), se não existir, usa o username %>
                                <%= (user.nickname || user.global_name || user.username) %>
                            </span>
                            <a href="/logout" class="text-titan-cream opacity-50 hover:opacity-100 text-sm underline">Sair</a>
                        </div>
                    </div>

                    <!-- Grid de Servidores -->
                    <% if (guilds.length > 0) { %>
                        <div class="grid"
                             style="grid-template-columns: repeat(3, minmax(30px, 72px)); gap: clamp(8px, 1.6vw, 14px); width: 100%; max-width: 244px;">

                            <% /* Sempre 3 colunas (mantem a organizacao do design) - quem encolhe pra
                                caber na tela e o tamanho de cada icone (minmax), nao a quantidade de
                                colunas. Mostra TODOS os servidores que a pessoa administra — sem limite de 6. */ %>
                            <% guilds.forEach(guild => { %>
                                <a href="/home/<%= guild.id %>"
                                   class="bg-titan-dark flex items-center justify-center cursor-pointer transition-all duration-200 hover:border-titan-accent hover:scale-105"
                                   style="aspect-ratio: 1 / 1; border-radius: 18.75%; border: 2px solid #3E3D38; box-shadow: 0 12px 18px 6px rgba(1, 2, 10, 0.38); overflow: hidden;">
                                    <% if (guild.icon) { %>
                                        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="guild-icon-img">
                                    <% } else { %>
                                        <%# Sem ícone de servidor: um dos 4 ícones do design (fixo por
                                            servidor, mesmo padrão já usado no avatar do Discord acima) %>
                                        <img src="/images/guild-fallback-<%= (guild.id % 4) + 1 %>.svg" class="guild-icon-img">
                                    <% } %>
                                </a>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <!-- TEMPORÁRIO: sem o ícone/ilustração do Figma pra esse estado vazio ainda —
                             troca por texto simples até o design ser enviado. -->
                        <div class="flex flex-col items-center gap-3 opacity-60">
                            <p class="text-titan-cream text-center" style="font-family: 'Poppins', sans-serif; font-size: 16px;">
                                Nenhum servidor encontrado. Adicione o bot em um servidor pra gerenciá-lo aqui.
                            </p>
                        </div>
                    <% } %>

                <% } else { %>
                    <!-- Caso não esteja logado -->
                    <div class="flex flex-col items-center gap-6">
                        <a href="/login" class="btn-primary">
                            <span class="btn-primary-icon"></span>
                            <span>ENTRAR COM DISCORD</span>
                        </a>
                    </div>
                <% } %>

            </div>
        </div>

        <!-- Footer -->
        <div class="text-center py-2 flex flex-col items-center gap-1">
            <a href="/termos" class="text-titan-cream opacity-60 hover:opacity-100 underline" style="font-family: 'Poppins', sans-serif; font-size: 14px;">
                Termos de Serviço
            </a>
            <span class="text-titan-cream opacity-60" style="font-family: 'Poppins', sans-serif; font-size: 16px;">
                BY: KNUST SEIER VI
            </span>
        </div>
    </div>

</body>
</html>