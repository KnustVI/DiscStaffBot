<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Moderação | <%= bot.user.username %></title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&family=Bebas+Neue&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'titan-bg': '#0D0D0D',
                        'titan-accent': '#803E30',
                        'titan-cream': '#F8DCC0',
                        'titan-gold': '#D9A362',
                    }
                }
            }
        }
    </script>
</head>
<body class="flex min-h-screen">

    <aside class="shrink-0 h-screen sticky top-0 py-[30px] pl-[30px] hidden lg:block">
        <%- include('partials/sidebar-v2', { active: 'moderacao', guild, nickname, role }) %>
    </aside>

    <main class="flex-1 w-full flex flex-col p-[30px] gap-[30px] overflow-y-auto">

        <%- include('partials/page-header', { guild, pageLabel: 'MODERAÇÃO', pageRoute, otherGuilds }) %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="titan-card-premium !py-4 !px-6 text-sm text-titan-gold">Configurações salvas.</div>
        <% } %>

        <!-- ALERTA (mesmo visual outline-chip da lista de staff, pedido do dono) -->
        <section class="flex flex-col gap-3">
            <% if (openReportsAlert.length === 0) { %>
                <div class="outline-chip is-lg">
                    <i data-lucide="shield-check" class="outline-chip-icon"></i>
                    <div class="outline-chip-text">
                        <span class="outline-chip-headline">Nenhum Alerta</span>
                        <span class="outline-chip-subtitle">Nada novo por aqui.....</span>
                    </div>
                </div>
            <% } else { %>
                <% openReportsAlert.forEach(r => { %>
                    <div class="outline-chip is-lg is-bad">
                        <i data-lucide="shield-alert" class="outline-chip-icon"></i>
                        <div class="outline-chip-text">
                            <span class="outline-chip-headline"><%= r.report_id %></span>
                            <span class="outline-chip-subtitle">Aguardando staff — aberto por <@<%= r.user_id %>> em <%= new Date(r.created_at).toLocaleString('pt-BR') %></span>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </section>

        <div id="ingamePulseRoot" data-guild-id="<%= guild.id %>" data-show-roster="true">
            <%- include('partials/ingame-pulse', { pulse }) %>
        </div>

        <%
            // MODERAÇÃO/Punições e AUTOMODERAÇÃO seguem o MESMO padrão do
            // IN GAME (confirmado por extração + conferência do
            // Moderação.txt): 4 donuts, os 3 primeiros dourados
            // (GraphicStyle) e o 4º maior/destacado em terracota
            // (GraphicStyle2) — não 2 como a versão anterior tinha. O
            // grande sempre por último no HTML (fica à direita/na frente,
            // ver graph-card.ejs).
            const punDonutsHtml =
                include('partials/stat-donut', { id: 'pun-ativas', title: 'Ativas', value: `${punActive}`, percent: punTotal > 0 ? (punActive / punTotal) * 100 : 0, accent: 'gold' }) +
                include('partials/stat-donut', { id: 'pun-revogadas', title: 'Revogadas', value: `${punRevoked}`, percent: punTotal > 0 ? (punRevoked / punTotal) * 100 : 0, accent: 'gold' }) +
                include('partials/stat-donut', { id: 'pun-graves', title: 'Graves/Severas', value: `${punHighSeverity}`, percent: punTotal > 0 ? (punHighSeverity / punTotal) * 100 : 0, accent: 'gold' }) +
                include('partials/stat-donut', { id: 'pun-total', title: 'Total Aplicadas', value: `${punTotal}`, percent: 100, accent: 'red', size: 'big' });

            const autoDonutsHtml =
                include('partials/stat-donut', { id: 'auto-palavras', title: 'Palavras Filtradas', value: `${filterWordCount}`, percent: 100, accent: 'gold' }) +
                include('partials/stat-donut', { id: 'auto-niveis', title: 'Níveis Configurados', value: `${filterLevelCount}`, percent: 100, accent: 'gold' }) +
                include('partials/stat-donut', { id: 'auto-punicoes', title: 'Punições Automáticas', value: `${autoPunishments}/${punTotal}`, percent: punTotal > 0 ? (autoPunishments / punTotal) * 100 : 0, accent: 'gold' }) +
                include('partials/stat-donut', { id: 'auto-total', title: 'Total de Punições', value: `${punTotal}`, percent: 100, accent: 'red', size: 'big' });
        %>

        <!-- MODERAÇÃO -->
        <section class="flex flex-col gap-3">
            <h2 class="section-title text-sm px-2">Punições</h2>
            <%- include('partials/graph-card', { bodyHtml: punDonutsHtml }) %>
        </section>

        <!-- AUTOMODERAÇÃO -->
        <section class="flex flex-col gap-3">
            <h2 class="section-title text-sm px-2">Automoderação</h2>
            <%- include('partials/graph-card', { bodyHtml: autoDonutsHtml }) %>
        </section>

        <%#
            CONFIGURAÇÕES (Moderação.txt linhas 4523-7213, extraído + conferido
            2x contra o arquivo). 3 cards, cada um com SEU PRÓPRIO form + botão
            Salvar (espelha o Figma: cada painel tem seu próprio
            BaseButtonCard/Button.text no final, não um botão único pra tudo) —
            também evita que salvar um card apague campos dos outros dois
            (dashboard.js só grava as chaves presentes no req.body de cada
            submit). Campos de cargo usam partials/role-picker (Figma
            "TextFieldMobile" — cápsula + botão circular de adicionar) em
            vez do TextFieldWeb de texto livre, porque a config real do bot
            é sempre um Discord role id, não uma string digitada. Cada
            campo vira select simples OU chips+botão "+" dependendo do
            limite de cargos do tier atual (roleLimits, mesmo
            PremiumSystem.getRoleLimit do painel /config roles do Discord)
            — MODERADOR/SUPERVISOR aceitam mais de um cargo a partir do
            Rastreador/Caçador; STRIKE/EXEMPLAR/PROBLEMÁTICO são sempre um
            só (sem roleLimitKey em configSystem.js).
        %>
        <section class="flex flex-col gap-6">
            <h2 class="section-title text-sm px-2">Configurações</h2>

            <form action="/moderacao/<%= guild.id %>/save" method="POST" class="config-card">
                <div class="config-card-header">
                    <i data-lucide="shield-check" class="config-card-icon"></i>
                    <h3 class="config-card-title">Cargos de Moderação</h3>
                </div>
                <p class="config-card-desc">Cargos que controlam quem pode usar os comandos de moderação e quem pode aprovar as punições mais severas. Detalhes de cada um abaixo. O número de cargos permitido por campo varia com o plano (use <code>/premium</code> pra aumentar).</p>

                <div class="config-fields">
                    <div class="config-field">
                        <div class="config-field-row">
                            <i data-lucide="shield" class="config-field-icon"></i>
                            <div class="config-field-text">
                                <div class="config-field-label-row"><span class="config-field-label">MODERADOR</span></div>
                                <p class="config-field-desc">Permite usar os comandos de moderação (/strike, /unstrike, /historico) e atender reports no ReportChat.</p>
                            </div>
                        </div>
                        <%- include('partials/role-picker', { id: 'staff-role', name: 'staff_role', roles, selectedIds: staffRoleIds, limit: roleLimits.moderador }) %>
                    </div>

                    <div class="config-field">
                        <div class="config-field-row">
                            <i data-lucide="eye" class="config-field-icon"></i>
                            <div class="config-field-text">
                                <div class="config-field-label-row"><span class="config-field-label">SUPERVISOR</span></div>
                                <p class="config-field-desc">Tem autoridade para aprovar ou aplicar diretamente punições severas (níveis de severidade Grave ou Severa, ou qualquer punição com duração maior que 72h/permanente).</p>
                            </div>
                        </div>
                        <%- include('partials/role-picker', { id: 'supervisor-role', name: 'supervisor_role', roles, selectedIds: supervisorRoleIds, limit: roleLimits.supervisor }) %>
                    </div>
                </div>

                <button type="submit" class="config-save-btn"><i data-lucide="save" class="config-save-icon"></i>Salvar</button>
            </form>

            <form action="/moderacao/<%= guild.id %>/save" method="POST" class="config-card">
                <div class="config-card-header">
                    <i data-lucide="shield-alert" class="config-card-icon"></i>
                    <h3 class="config-card-title">Cargos Automáticos — Reputação</h3>
                </div>
                <p class="config-card-desc">Estes cargos são atribuídos e removidos automaticamente pelo sistema de reputação, não é necessário atribuí-los manualmente. Detalhes de cada um abaixo.</p>

                <div class="config-fields">
                    <div class="config-field">
                        <div class="config-field-row">
                            <i data-lucide="shield-off" class="config-field-icon"></i>
                            <div class="config-field-text">
                                <div class="config-field-label-row"><span class="config-field-label">STRIKE</span></div>
                                <p class="config-field-desc">Atribuído automaticamente enquanto uma punição temporária está ativa. Removido quando a punição expira ou é anulada.</p>
                            </div>
                        </div>
                        <%- include('partials/role-picker', { id: 'strike-role', name: 'strike_role', roles, selectedIds: settings.strike_role ? [settings.strike_role] : [], limit: 1 }) %>
                    </div>

                    <div class="config-field">
                        <div class="config-field-row">
                            <i data-lucide="thumbs-up" class="config-field-icon"></i>
                            <div class="config-field-text">
                                <div class="config-field-label-row">
                                    <span class="config-field-label">EXEMPLAR</span>
                                    <span class="config-tier-badge">CAÇADOR</span>
                                </div>
                                <p class="config-field-desc">Atribuído automaticamente a membros com reputação acima do limite configurado em /config punishments. Indica bom comportamento.</p>
                            </div>
                        </div>
                        <%- include('partials/role-picker', { id: 'role-exemplar', name: 'role_exemplar', roles, selectedIds: settings.role_exemplar ? [settings.role_exemplar] : [], limit: 1 }) %>
                    </div>

                    <div class="config-field">
                        <div class="config-field-row">
                            <i data-lucide="thumbs-down" class="config-field-icon"></i>
                            <div class="config-field-text">
                                <div class="config-field-label-row">
                                    <span class="config-field-label">PROBLEMÁTICO</span>
                                    <span class="config-tier-badge">CAÇADOR</span>
                                </div>
                                <p class="config-field-desc">Atribuído automaticamente a membros com reputação abaixo do limite configurado em /config punishments. Sinaliza comportamento problemático.</p>
                            </div>
                        </div>
                        <%- include('partials/role-picker', { id: 'role-problematico', name: 'role_problematico', roles, selectedIds: settings.role_problematico ? [settings.role_problematico] : [], limit: 1 }) %>
                    </div>
                </div>

                <button type="submit" class="config-save-btn"><i data-lucide="save" class="config-save-icon"></i>Salvar</button>
            </form>

            <div class="config-card">
                <div class="config-card-header">
                    <i data-lucide="palette" class="config-card-icon"></i>
                    <h3 class="config-card-title">Personalização</h3>
                    <span class="config-tier-badge">CAÇADOR</span>
                </div>

                <% if (!isCacador) { %>
                    <p class="config-card-desc">Exclusivo do plano Caçador — use <code>/premium</code> pra saber mais.</p>
                <% } else { %>
                    <p class="config-card-desc">Para deixar a cara do seu servidor.</p>

                    <form action="/moderacao/<%= guild.id %>/save" method="POST" class="config-fields">
                        <div class="config-field">
                            <div class="config-field-row">
                                <i data-lucide="palette" class="config-field-icon"></i>
                                <div class="config-field-text">
                                    <div class="config-field-label-row"><span class="config-field-label">COR (#<%= settings.panel_accent_color || 'DCA15E' %>)</span></div>
                                    <p class="config-field-desc">Cor da borda dos painéis.</p>
                                </div>
                            </div>
                            <div class="config-field-input">
                                <div class="config-field-input-inner">
                                    <input type="text" maxlength="6" class="config-field-text-input" name="panel_accent_color" placeholder="DCA15E" value="<%= settings.panel_accent_color || '' %>">
                                </div>
                            </div>
                        </div>

                        <div class="config-field">
                            <div class="config-field-row">
                                <i data-lucide="edit" class="config-field-icon"></i>
                                <div class="config-field-text">
                                    <div class="config-field-label-row"><span class="config-field-label">FOOTER</span></div>
                                    <p class="config-field-desc">Assinatura abaixo dos painéis.</p>
                                </div>
                            </div>
                            <div class="config-field-input">
                                <div class="config-field-input-inner">
                                    <input type="text" maxlength="100" class="config-field-text-input" name="panel_footer_text" placeholder="BY: KNUST SEIER VI" value="<%= settings.panel_footer_text || '' %>">
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="config-save-btn"><i data-lucide="save" class="config-save-icon"></i>Salvar</button>
                    </form>

                    <h4 class="config-subtitle">Strike e Unstrike</h4>

                    <div class="config-fields">
                        <div class="config-field">
                            <div class="config-field-row">
                                <i data-lucide="image" class="config-field-icon"></i>
                                <div class="config-field-text">
                                    <div class="config-field-label-row"><span class="config-field-label">BANNER STRIKE</span></div>
                                    <p class="config-field-desc">Capa do painel</p>
                                </div>
                            </div>
                            <div class="config-banner-preview" style="background-image: url('/images/title-strike.webp');"></div>
                        </div>

                        <div class="config-field">
                            <div class="config-field-row">
                                <i data-lucide="image" class="config-field-icon"></i>
                                <div class="config-field-text">
                                    <div class="config-field-label-row"><span class="config-field-label">BANNER UNSTRIKE</span></div>
                                    <p class="config-field-desc">Capa do painel</p>
                                </div>
                            </div>
                            <div class="config-banner-preview" style="background-image: url('/images/title-strike-removido.webp');"></div>
                        </div>
                    </div>
                <% } %>
            </div>
        </section>

        <footer class="flex justify-end pb-2">
            <span class="bebas text-[12px] uppercase tracking-[6px] text-titan-cream opacity-10 hover:opacity-30 transition-opacity">
                BY: KNUST SEIER VI
            </span>
        </footer>
    </main>

    <script>if (window.lucide) window.lucide.createIcons();</script>
    <script src="/js/ingame-pulse-poll.js"></script>
    <script src="/js/role-picker.js"></script>
</body>
</html>
