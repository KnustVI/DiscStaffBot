<%#
  web/views/partials/page-header.ejs
  Cabeçalho "DASHBOARD" + "SERVERNAME | PÁGINA" + ícone do servidor (spec
  Figma: Frame 18/19/20/21, idêntico nas 3 páginas — Moderação/Reports/
  Events só trocam o texto da página).

  Comentário de verdade do EJS (abre com "menor, porcento"), não HTML —
  esse tipo de comentário some do HTML final, o EJS descarta antes de
  gerar a página. Mesmo assim sem os delimitadores reais de tag do EJS no
  exemplo abaixo de propósito: esse tipo de comentário não aceita outra
  tag de EJS aninhada dentro dele (testado — quebra o parser).

  Uso: include( partials/page-header , { guild, pageLabel, pageRoute, otherGuilds } ) —
  pageLabel é o texto depois do "|" (ex: MODERAÇÃO/REPORTES/EVENTOS).
  pageRoute/otherGuilds são OPCIONAIS (pedido do dono: ícone do servidor
  vira um seletor pra trocar de servidor sem voltar pro /dashboard) —
  pageRoute é o prefixo da rota atual ('moderacao'/'reports'/'events') e
  otherGuilds é a lista (já filtrada: admin + bot presente, mesmo critério
  de /dashboard) de TODOS os servidores do usuário, incluindo o atual —
  o dropdown exclui o atual e linka pra /<pageRoute>/<outroId>. Sem os
  dois, ou com só o servidor atual na lista, o ícone fica só decorativo
  (sem nada pra trocar).
%>
<%
    // Mesmo padrão de fallback (sem ícone) já usado em index.ejs.
    const phIconUrl = guild.icon
        ? `https://cdn.discordapp.com/icons/${guild.id}/${guild.icon}.png`
        : `/images/guild-fallback-${(guild.id % 4) + 1}.svg`;

    const phRoute = typeof pageRoute !== 'undefined' ? pageRoute : null;
    const phOtherGuilds = (typeof otherGuilds !== 'undefined' && Array.isArray(otherGuilds))
        ? otherGuilds.filter(g => g.id !== guild.id)
        : [];
    const phCanSwitch = phRoute && phOtherGuilds.length > 0;
%>
<header class="page-header">
    <div class="page-header-text">
        <h1 class="page-header-title">DASHBOARD</h1>
        <p class="page-header-subtitle"><%= guild.name %> | <%= pageLabel %></p>
    </div>

    <% if (phCanSwitch) { %>
        <div class="page-header-switcher">
            <button type="button" class="page-header-icon page-header-icon-btn" id="phSwitcherBtn" aria-haspopup="true" aria-expanded="false" aria-label="Trocar de servidor">
                <img src="<%= phIconUrl %>" alt="">
                <span class="page-header-icon-badge"><i data-lucide="chevron-down"></i></span>
            </button>
            <div class="page-header-switcher-menu" id="phSwitcherMenu" role="menu">
                <span class="page-header-switcher-label">Trocar de servidor</span>
                <% phOtherGuilds.forEach(g => { %>
                    <%
                        const gIconUrl = g.icon
                            ? `https://cdn.discordapp.com/icons/${g.id}/${g.icon}.png`
                            : `/images/guild-fallback-${(g.id % 4) + 1}.svg`;
                    %>
                    <a href="/<%= phRoute %>/<%= g.id %>" class="page-header-switcher-item" role="menuitem">
                        <img src="<%= gIconUrl %>" alt="">
                        <span><%= g.name %></span>
                    </a>
                <% }); %>
                <a href="/dashboard" class="page-header-switcher-item page-header-switcher-all" role="menuitem">
                    <i data-lucide="layout-grid"></i>
                    <span>Ver todos os servidores</span>
                </a>
            </div>
        </div>
    <% } else { %>
        <div class="page-header-icon">
            <img src="<%= phIconUrl %>" alt="">
        </div>
    <% } %>
</header>
<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        padding: 0 8px;
    }
    .page-header-text { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
    .page-header-title {
        font-family: 'Poppins', sans-serif;
        font-weight: 400;
        font-size: clamp(18px, 3vw, 30px);
        line-height: 1.4;
        letter-spacing: 0.3em;
        color: #DCA15E;
        white-space: nowrap;
    }
    .page-header-subtitle {
        font-family: 'Poppins', sans-serif;
        font-weight: 400;
        font-size: clamp(12px, 1.6vw, 18px);
        line-height: 1.4;
        letter-spacing: 0.3em;
        color: #F8DCC0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .page-header-icon {
        box-sizing: border-box;
        flex: none;
        width: clamp(56px, 7vw, 80px);
        height: clamp(56px, 7vw, 80px);
        border: 2px solid #803E30;
        border-radius: 15px;
        box-shadow: 0px 12px 18px 11px rgba(1, 2, 10, 0.45);
        overflow: hidden;
        background: #4B2427;
    }
    .page-header-icon img { width: 100%; height: 100%; object-fit: cover; }
    @media (max-width: 480px) {
        .page-header-subtitle { letter-spacing: 0.15em; }
        .page-header-title { letter-spacing: 0.15em; }
    }

    /* Ícone vira um botão (mesmo tamanho/borda/sombra de .page-header-icon)
       quando há outro servidor pra trocar — pedido do dono. */
    .page-header-switcher { position: relative; flex: none; }
    .page-header-icon-btn {
        appearance: none;
        -webkit-appearance: none;
        padding: 0;
        cursor: pointer;
        position: relative;
        font: inherit;
        outline: none;
        transition: border-color 0.15s ease;
    }
    .page-header-icon-btn:hover,
    .page-header-icon-btn[aria-expanded="true"] { border-color: #F8DCC0; }
    .page-header-icon-badge {
        position: absolute;
        right: -4px;
        bottom: -4px;
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #2A2A2A;
        border: 2px solid #803E30;
        border-radius: 50%;
        color: #F8DCC0;
        pointer-events: none;
    }
    .page-header-icon-badge i { width: 12px; height: 12px; }
    .page-header-icon-btn[aria-expanded="true"] .page-header-icon-badge { transform: rotate(180deg); }

    /* Dropdown — mesma família visual dos cards escuros do site
       (BgGradient + CardShasow já usados em graph-card.ejs/config-card). */
    .page-header-switcher-menu {
        display: none;
        position: absolute;
        top: calc(100% + 10px);
        right: 0;
        z-index: 30;
        flex-direction: column;
        gap: 4px;
        width: max(220px, 100%);
        max-width: min(320px, 90vw);
        max-height: 60vh;
        overflow-y: auto;
        padding: 10px;
        background: radial-gradient(225.25% 94.36% at 0% 86.37%, #111111 0%, #1F1D20 57.07%, #29272A 91.53%);
        border: 1px solid #3E3D38;
        border-radius: 14px;
        box-shadow: -15px 30px 50px rgba(0, 0, 0, 0.8);
    }
    .page-header-switcher-menu.is-open { display: flex; }
    .page-header-switcher-label {
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #A89986;
        padding: 4px 8px 6px;
    }
    .page-header-switcher-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px;
        border-radius: 10px;
        text-decoration: none;
        color: #F8DCC0;
        font-family: 'Poppins', sans-serif;
        font-size: 13px;
        font-weight: 400;
        transition: background 0.12s ease;
    }
    .page-header-switcher-item:hover { background: rgba(248, 220, 192, 0.08); }
    .page-header-switcher-item img {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        object-fit: cover;
        flex: none;
    }
    .page-header-switcher-item span {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    .page-header-switcher-all {
        border-top: 1px solid #3E3D38;
        margin-top: 4px;
        padding-top: 10px;
        color: #A89986;
    }
    .page-header-switcher-all i { width: 18px; height: 18px; flex: none; }
</style>
<script>
    (function () {
        var btn = document.getElementById('phSwitcherBtn');
        var menu = document.getElementById('phSwitcherMenu');
        if (!btn || !menu) return;

        function closeMenu() {
            menu.classList.remove('is-open');
            btn.setAttribute('aria-expanded', 'false');
        }
        function toggleMenu() {
            var willOpen = !menu.classList.contains('is-open');
            menu.classList.toggle('is-open', willOpen);
            btn.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        }

        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            toggleMenu();
        });
        document.addEventListener('click', function (e) {
            if (!menu.contains(e.target) && e.target !== btn) closeMenu();
        });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeMenu();
        });
    })();
</script>
