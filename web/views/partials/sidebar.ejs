<!-- SIDEBAR: Bloco único e contínuo -->
<aside class="flex flex-col w-[300px] h-[calc(100vh-60px)] items-center justify-between px-6 py-10 fixed left-[30px] top-[30px] z-50 titan-card-premium shadow-[-25px_47px_68px_rgba(0,0,0,0.74)]">
    
    <!-- TOP SECTION: Logo -->
    <div class="flex flex-col items-center w-full">
        <img 
            class="w-48 h-auto object-contain transition-transform hover:scale-105 duration-500"
            alt="Titans pass logo"
            src="https://c.animaapp.com/mnb8jqp9dw8rx4/img/titans-pass-logo-1.png"
        />
    </div>

    <!-- MIDDLE SECTION: Navigation Menu -->
    <nav class="flex flex-col items-center gap-3 w-full my-8 overflow-y-auto custom-scrollbar">
        <% 
        const navItems = [
            { label: "CONFIGURAÇÕES", path: "manage" },
            { label: "IN GAME", path: "ingame" },
            { label: "TICKETS", path: "tickets" },
            { label: "STAFFS", path: "staffs" },
            { label: "STRIKES", path: "strikes" },
            { label: "PERFIL", path: "profile" }
        ];
        %>

        <% navItems.forEach(item => { %>
            <a href="/<%= item.path %>/<%= guild.id %>" 
               class="flex w-full h-[42px] items-center justify-center rounded-[12px] border border-[#803e30]/50 shadow-md transition-all duration-300 group <%= (typeof path !== 'undefined' && path === item.path) ? 'bg-[#3a2020] border-[#f8dcc0]/30' : 'bg-[#292929]' %> hover:bg-[#3a2020]">
                
                <span class="[font-family:'Poppins',Helvetica] font-medium text-[#f8dcc0] text-sm tracking-widest uppercase">
                    <%= item.label %>
                </span>
            </a>
        <% }); %>
    </nav>

    <!-- BOTTOM SECTION: User Profile -->
    <div class="mt-auto flex flex-col items-center w-full">
        
        <!-- Avatar -->
        <div class="relative w-20 h-20 mb-4 shrink-0 rounded-full border-2 border-[#803e30] shadow-[0px_4px_20px_rgba(0,0,0,0.7)] overflow-hidden">
            <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" 
                 alt="Avatar" class="w-full h-full object-cover bg-[#292929]">
        </div>

        <!-- Info (Nome e Cargo) -->
        <div class="flex flex-col items-center w-full text-center">
            <span class="[font-family:'Tilt_Warp',Helvetica] font-normal text-[#f8dcc0] text-lg tracking-[0.5px] leading-tight uppercase w-full mb-3">
                <%= nickname %>
            </span>
            
            <!-- Cargo: Fundo vermelho centralizado sem linha superior -->
            <div class="flex items-center justify-center px-6 py-1.5 bg-[#4b2427] rounded-full border border-[#f8dcc0]/20 shadow-[0px_8px_15px_rgba(0,0,0,0.5)]">
                <span class="[font-family:'Bebas_Neue',Helvetica] font-normal text-[#f8dcc0] text-xs tracking-[1.5px] leading-none uppercase whitespace-nowrap">
                    <%= role %>
                </span>
            </div>
        </div>

        <!-- Logout: Posicionado com margem superior para não colar -->
        <div class="mt-6 w-full flex justify-center">
            <a href="/logout" class="text-[10px] text-white/20 hover:text-red-400 transition-colors uppercase tracking-[3px] font-light">
                Sair
            </a>
        </div>
    </div>
</aside>