<!--
  web/views/partials/ingame-pulse.ejs
  Bloco "IN GAME" do Figma (Moderação.txt/Reports.txt/Events.txt repetem
  essa seção) — painel com 3 donuts (Jogando / Em modo espectador /
  Moderadores online) + grade STAFF ONLINE/STAFF OFFLINE (Moderação e
  Events only — Reports só tem os donuts, ver showRoster abaixo).

  "Em modo espectador" = staff com sessão aberta em
  pot_spectator_sessions (ligado via AdminSpectate no jogo) — dado real,
  não presença do Discord (o bot não tem a intent GuildPresences). "Staff
  offline" cobre quem tem o cargo de staff mas não está online no jogo.

  Uso: include( partials/ingame-pulse , { pulse, showRoster } ) —
  showRoster é opcional, default true; sem os delimitadores reais de tag
  do EJS aqui de propósito, um deles de verdade dentro deste comentário
  HTML seria executado pelo EJS mesmo assim (já quebrou a página uma vez,
  ver o mesmo aviso em sidebar-v2.ejs).
-->
<% const ipShowRoster = typeof showRoster === 'undefined' || showRoster; %>
<section class="ingame-pulse">
    <h2 class="ingame-pulse-title">IN GAME</h2>
    <div class="ingame-pulse-panel">
        <%- include('stat-donut', {
            title: 'Jogando',
            value: `${pulse.staffPlaying}/${pulse.staffTotal}`,
            percent: pulse.staffTotal > 0 ? (pulse.staffPlaying / pulse.staffTotal) * 100 : 0,
            accent: 'gold',
        }) %>
        <%- include('stat-donut', {
            title: 'Em modo espectador',
            value: `${pulse.staffSpectating}/${pulse.staffTotal}`,
            percent: pulse.staffTotal > 0 ? (pulse.staffSpectating / pulse.staffTotal) * 100 : 0,
            accent: 'gold',
        }) %>
        <%- include('stat-donut', {
            title: 'Moderadores online',
            value: `${pulse.staffOnline}/${pulse.staffTotal}`,
            percent: pulse.staffTotal > 0 ? (pulse.staffOnline / pulse.staffTotal) * 100 : 0,
            accent: 'red',
            size: 'big',
        }) %>
    </div>

    <% if (ipShowRoster) { %>
        <% const online = pulse.roster.filter(s => s.online); const offline = pulse.roster.filter(s => !s.online); %>
        <% if (pulse.roster.length === 0) { %>
            <p class="text-sm opacity-40 text-center mt-4">Nenhum cargo de staff configurado ainda.</p>
        <% } else { %>
            <div class="ingame-staff-grid">
                <% online.forEach(staff => { %>
                    <div class="ingame-staff-chip is-online">
                        <i data-lucide="power" class="ingame-staff-icon"></i>
                        <div class="flex flex-col">
                            <span class="ingame-staff-headline">STAFF ONLINE</span>
                            <span class="ingame-staff-status"><%= staff.moderating ? 'MODERANDO...' : 'JOGANDO...' %></span>
                        </div>
                    </div>
                <% }); %>
                <% offline.forEach(staff => { %>
                    <div class="ingame-staff-chip is-offline">
                        <i data-lucide="power" class="ingame-staff-icon"></i>
                        <div class="flex flex-col">
                            <span class="ingame-staff-headline">STAFF OFFLINE</span>
                            <span class="ingame-staff-status">...</span>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    <% } %>
</section>
<style>
    .ingame-pulse { display: flex; flex-direction: column; gap: 12px; width: 100%; }
    .ingame-pulse-title {
        font-family: 'Poppins', sans-serif;
        font-weight: 400;
        font-size: clamp(16px, 2vw, 24px);
        line-height: 1.5;
        letter-spacing: 0.3em;
        color: #FFFFFF;
        text-align: center;
        text-transform: uppercase;
    }
    .ingame-pulse-panel {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: flex-end;
        gap: 4px;
        min-height: 220px;
        padding: 20px clamp(16px, 4vw, 50px);
        background: radial-gradient(225.25% 94.36% at 0% 86.37%, #111111 0%, #1F1D20 57.07%, #29272A 91.53%);
        box-shadow: 0.5px -0.5px 0.5px #F8DCC0, -25px 47px 68.1px rgba(0, 0, 0, 0.74);
        border-radius: 20px;
    }

    .ingame-staff-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 16px;
    }
    .ingame-staff-chip {
        box-sizing: border-box;
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 20px;
        border-radius: 10px;
        border: 1px solid;
        background: var(--bg-card);
    }
    .ingame-staff-chip.is-online { border-color: #A5FFA1; }
    .ingame-staff-chip.is-offline { border-color: #FF4E3B; }
    .ingame-staff-icon { width: 34px; height: 34px; flex: none; }
    .ingame-staff-chip.is-online .ingame-staff-icon { color: #A5FFA1; }
    .ingame-staff-chip.is-offline .ingame-staff-icon { color: #FF4E3B; }
    .ingame-staff-headline {
        font-family: 'Tilt Warp', sans-serif;
        font-size: clamp(18px, 2.2vw, 26px);
        line-height: 1.2;
        color: #DCA15E;
        text-transform: uppercase;
    }
    .ingame-staff-status {
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 14px;
        color: #F8DCC0;
        opacity: 0.85;
    }
</style>
