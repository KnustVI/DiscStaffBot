<%#
  web/views/partials/ingame-pulse.ejs
  Bloco "IN GAME" do Figma (Moderação.txt/Reports.txt/Events.txt repetem
  essa seção) — 3 donuts dentro de partials/graph-card (Jogando / Em modo
  espectador / Jogadores Online) + grade STAFF ONLINE/STAFF OFFLINE
  (Moderação e Events only — Reports só tem os donuts, ver showRoster
  abaixo).

  O donut maior fica SEMPRE por último (mais à direita, com
  justify-content:flex-end do card) e é SEMPRE "Jogadores Online" sobre
  120 (capacidade máxima de um servidor de Path of Titans) — pedido do
  dono, não é staff, é a contagem geral de jogadores no jogo. "Jogando"/
  "Em modo espectador" continuam sendo sobre STAFF (pot_spectator_sessions
  = sessão de AdminSpectate aberta no jogo, dado real, não presença do
  Discord — o bot não tem a intent GuildPresences).

  Uso: include( partials/ingame-pulse , { pulse, showRoster } ) —
  showRoster é opcional, default true.

  Este é um comentário de verdade do EJS (abre com "menor, porcento"),
  não um comentário de HTML — um comentário de HTML aparece no código
  fonte que o navegador recebe (o navegador só esconde visualmente, o
  texto continua lá), enquanto este daqui o EJS descarta antes de gerar a
  página. Mesmo assim, sem os delimitadores reais de tag do EJS no exemplo
  acima de propósito: um comentário deste tipo NÃO aceita outra tag de EJS
  aninhada dentro dele (testado — quebra o parser), então nada de tag real
  aqui dentro, nem pra exemplo.
%>
<%
    const ipShowRoster = typeof showRoster === 'undefined' || showRoster;
    const IP_MAX_PLAYERS = 120; // capacidade máxima de um servidor de Path of Titans

    // Ordem importa: o maior/destaque precisa ser o ÚLTIMO no HTML pra
    // sobrar à direita com justify-content:flex-end (ver graph-card.ejs).
    const ipDonutsHtml =
        include('stat-donut', {
            title: 'Jogando',
            value: `${pulse.staffPlaying}/${pulse.staffTotal}`,
            percent: pulse.staffTotal > 0 ? (pulse.staffPlaying / pulse.staffTotal) * 100 : 0,
            accent: 'gold',
        }) +
        include('stat-donut', {
            title: 'Em modo espectador',
            value: `${pulse.staffSpectating}/${pulse.staffTotal}`,
            percent: pulse.staffTotal > 0 ? (pulse.staffSpectating / pulse.staffTotal) * 100 : 0,
            accent: 'gold',
        }) +
        include('stat-donut', {
            title: 'Jogadores Online',
            value: `${pulse.playersOnline}/${IP_MAX_PLAYERS}`,
            percent: (pulse.playersOnline / IP_MAX_PLAYERS) * 100,
            accent: 'red',
            size: 'big',
        });
%>
<section class="ingame-pulse">
    <h2 class="ingame-pulse-title">IN GAME</h2>
    <%- include('graph-card', { bodyHtml: ipDonutsHtml }) %>

    <% if (ipShowRoster) { %>
        <% const online = pulse.roster.filter(s => s.online); const offline = pulse.roster.filter(s => !s.online); %>
        <% if (pulse.roster.length === 0) { %>
            <p class="text-sm opacity-40 text-center ingame-staff-grid-spacing">Nenhum cargo de staff configurado ainda.</p>
        <% } else { %>
            <div class="ingame-staff-grid ingame-staff-grid-spacing">
                <% online.forEach(staff => { %>
                    <div class="outline-chip ingame-staff-icon-size">
                        <i data-lucide="power" class="outline-chip-icon"></i>
                        <div class="outline-chip-text">
                            <span class="outline-chip-headline"><%= staff.name %></span>
                            <span class="outline-chip-subtitle"><%= staff.moderating ? 'MODERANDO...' : 'JOGANDO...' %></span>
                        </div>
                    </div>
                <% }); %>
                <% offline.forEach(staff => { %>
                    <div class="outline-chip is-bad ingame-staff-icon-size">
                        <i data-lucide="power" class="outline-chip-icon"></i>
                        <div class="outline-chip-text">
                            <span class="outline-chip-headline"><%= staff.name %></span>
                            <span class="outline-chip-subtitle">...</span>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    <% } %>
</section>
<style>
    .ingame-pulse { display: flex; flex-direction: column; gap: 12px; width: 100%; }
    .ingame-pulse-title {
        font-family: 'Poppins', sans-serif;
        font-weight: 400;
        font-size: clamp(16px, 2vw, 24px);
        line-height: 1.5;
        letter-spacing: 0.3em;
        color: #FFFFFF;
        text-align: center;
        text-transform: uppercase;
    }

    /* 20px de respiro entre a lista de staff e o que vem antes/depois dela
       no site (pedido do dono) — separado do gap:12px genérico do
       .ingame-pulse (que é só entre título/card/lista). */
    .ingame-staff-grid-spacing { margin-top: 20px; margin-bottom: 20px; }
    /* Sempre 3 por linha (pedido do dono, mesmo em telas menores — o
       conteúdo encolhe/quebra dentro do chip em vez de reagrupar em menos
       colunas). */
    .ingame-staff-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }
    .ingame-staff-icon-size .outline-chip-icon { width: 40px; height: 40px; }
    @media (max-width: 640px) {
        .ingame-staff-grid { gap: 8px; }
    }
</style>
