<%#
  web/views/partials/stat-donut.ejs
  Anel de progresso reutilizável (spec Figma: "Donut Graphic"/"Frame 15",
  Title/Subtitle no centro) — SVG stroke-ring, não crop+conic-gradient (a
  tentativa anterior renderizou pequena/quebrada; o dono confirmou que a
  versão em anel SVG batia mais com o Figma, só faltava reposicionar).

  Comentário de verdade do EJS (abre com "menor, porcento"), não HTML —
  esse tipo de comentário some do HTML final (o de HTML só fica invisível
  no navegador, mas continua no código fonte) e o EJS descarta antes de
  gerar a página. Mesmo assim sem os delimitadores reais de tag do EJS no
  exemplo abaixo de propósito: esse tipo de comentário não aceita outra
  tag de EJS aninhada dentro dele (testado — quebra o parser).

  Uso:
    include( partials/stat-donut , {
      title: Jogadores Online ,
      value: 9/120 ,              // texto mostrado no centro do gráfico
      percent: 30,                // 0-100, preenchimento do anel
      accent: gold ,              // gold (#DCA15E, padrão) ou red (#803E30, --surface)
      size: big ,                 // opcional — 'big' pro donut maior/destaque (Figma: ~1.27x), omitir pro tamanho normal
    } )
%>
<%
    const dTitle = title;
    const dValue = value;
    const dPercent = Math.max(0, Math.min(100, Number(percent) || 0));
    const dAccent = typeof accent !== 'undefined' && accent === 'red' ? 'red' : 'gold';
    const dBig = typeof size !== 'undefined' && size === 'big';
    const R = 38;
    const CIRC = 2 * Math.PI * R;
    const dOffset = CIRC - (dPercent / 100) * CIRC;
%>
<div class="stat-donut<%= dBig ? ' is-big' : '' %>" style="--donut-accent: <%= dAccent === 'red' ? '#803E30' : '#DCA15E' %>;">
    <svg class="stat-donut-svg" viewBox="0 0 100 100">
        <circle class="stat-donut-track" cx="50" cy="50" r="<%= R %>"></circle>
        <circle class="stat-donut-fill"
                cx="50" cy="50" r="<%= R %>"
                stroke-dasharray="<%= CIRC.toFixed(2) %>"
                stroke-dashoffset="<%= dOffset.toFixed(2) %>">
        </circle>
    </svg>
    <div class="stat-donut-label">
        <span class="stat-donut-title"><%= dTitle %></span>
        <span class="stat-donut-value"><%= dValue %></span>
    </div>
</div>
<style>
    /* Tamanhos responsivos (clamp) em vez dos 224x241/282x307 fixos do
       Figma — padrão do site é sempre funcionar em mobile (ver
       web_ui_always_responsive). ~1.27x de diferença entre normal/big,
       mesma proporção do Figma (282/224). */
    .stat-donut {
        position: relative;
        flex: none;
        display: flex;
        align-items: center;
        justify-content: center;
        width: clamp(150px, 15vw, 210px);
        height: clamp(150px, 15vw, 210px);
        margin: 0 -22px;
        filter: drop-shadow(12px 15px 11.5px rgba(0, 0, 0, 0.36));
    }
    .stat-donut.is-big {
        width: clamp(190px, 19vw, 266px);
        height: clamp(190px, 19vw, 266px);
        margin: 0 -14px;
        z-index: 1;
    }
    /* Anel bem mais grosso que a 1a tentativa (15 -> 22, sobre raio 38) —
       o Figma usa um disco quase cheio, não uma linha fina — e o "trilho"
       (parte vazia) ganha um brilho na cor de destaque (mesma ideia do
       "box-shadow: 0 0 2.3px <accent>" do Figma nas duas Ellipses, cheia
       ou vazia) pra nunca ficar invisível mesmo quando o valor real é 0%. */
    .stat-donut-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        transform: rotate(-90deg);
        filter: drop-shadow(0 0 3px var(--donut-accent));
    }
    .stat-donut-track {
        fill: none;
        stroke: rgba(110, 106, 98, 0.45);
        stroke-width: 22;
    }
    .stat-donut-fill {
        fill: none;
        stroke: var(--donut-accent);
        stroke-width: 22;
        stroke-linecap: butt;
        transition: stroke-dashoffset 0.3s ease;
    }
    .stat-donut-label {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        text-align: center;
        padding: 0 16px;
        pointer-events: none;
    }
    .stat-donut-title, .stat-donut-value {
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: clamp(13px, 1.3vw, 20px);
        line-height: 1.3;
        color: #F8DCC0;
    }
</style>
