<%#
  web/views/partials/stat-donut.ejs
  Anel de progresso — usa as classes .premium-* que já existem em
  web/public/css/style.css (mesmas de home.ejs: container que recorta um
  SVG maior/rotacionado, 4 círculos empilhados pra dar profundidade/glow).
  Essa técnica foi confirmada correta pelo dono duas vezes (era a usada na
  primeira versão de moderacao.ejs, direto do Moderação.txt original) —
  as tentativas seguintes de "melhorar" trocando pra um anel próprio só
  pioraram; a única coisa que precisava de ajuste era o POSICIONAMENTO
  dentro do card (ver graph-card.ejs/ingame-pulse.ejs), não o anel em si.
  NÃO troque a técnica de novo sem confirmar antes.

  Comentário de verdade do EJS (abre com "menor, porcento"), não HTML —
  esse tipo de comentário some do HTML final (o de HTML só fica invisível
  no navegador, mas continua no código fonte) e o EJS descarta antes de
  gerar a página. Mesmo assim sem os delimitadores reais de tag do EJS no
  exemplo abaixo de propósito: esse tipo de comentário não aceita outra
  tag de EJS aninhada dentro dele (testado — quebra o parser).

  Uso:
    include( partials/stat-donut , {
      title: Jogadores Online ,
      value: 9/120 ,              // texto mostrado no centro do gráfico
      percent: 30,                // 0-100, preenchimento do anel
      accent: gold ,              // gold (padrão, --accent) ou red (--surface)
      size: big ,                 // opcional — 'big' pro donut maior/destaque (~1.26x), omitir pro tamanho normal
    } )
%>
<%
    const dTitle = title;
    const dValue = value;
    const dPercent = Math.max(0, Math.min(100, Number(percent) || 0));
    const dAccent = typeof accent !== 'undefined' && accent === 'red' ? 'red' : 'gold';
    const dBig = typeof size !== 'undefined' && size === 'big';
    const R = 35;
    const CIRC = 2 * Math.PI * R;
    const dOffset = CIRC - (dPercent / 100) * CIRC;
%>
<div class="relative flex items-center justify-center<%= dBig ? ' stat-donut-slot-big' : ' stat-donut-slot' %>">
    <div class="premium-card-graph-container<%= dBig ? ' is-big' : '' %><%= dAccent === 'red' ? ' is-red' : '' %>">
        <svg class="premium-graph-inner" viewBox="0 0 100 100">
            <circle class="premium-circle-34" cx="50" cy="50" r="<%= R %>"></circle>
            <circle class="premium-circle-shadow" cx="50" cy="50" r="<%= R %>"></circle>
            <circle class="premium-circle-bg" cx="50" cy="50" r="<%= R %>"></circle>
            <circle class="premium-circle-progress"
                    cx="50" cy="50" r="<%= R %>"
                    stroke-dasharray="<%= CIRC.toFixed(2) %>"
                    stroke-dashoffset="<%= dOffset.toFixed(2) %>">
            </circle>
        </svg>
        <div class="premium-graph-label-container">
            <span class="premium-graph-title"><%= dTitle %></span>
            <span class="premium-graph-value"><%= dValue %></span>
        </div>
    </div>
</div>
<style>
    /* Variante "big" (Figma: donut de destaque ~1.26x maior) — escala o
       container E o SVG interno na mesma proporção, o resto (raio,
       stroke-width, rotação) já escala sozinho junto por causa do viewBox. */
    .premium-card-graph-container.is-big { width: 189px; height: 202px; }
    .premium-card-graph-container.is-big .premium-graph-inner { width: 277px; height: 315px; top: -35px; left: -11px; }
    /* Variante "red" (Figma: GraphicStyle2, donut de Jogadores Online) —
       --accent é fixo dourado em style.css, aqui sobrescreve só a cor do
       preenchimento pra --surface (vermelho/terracota). */
    .premium-card-graph-container.is-red .premium-circle-progress { stroke: var(--surface); }
    .premium-card-graph-container.is-red .premium-circle-34,
    .premium-card-graph-container.is-red .premium-circle-shadow { filter: none; }

    /* Sobreposição entre donuts — valor exato do Figma (margin: 0 -30px
       nos pequenos, o grande não tem margem própria). Fica no wrapper, não
       no card em si, pra não interferir no recorte (overflow:hidden) do
       .premium-card-graph-container. */
    .stat-donut-slot { margin: 0 -30px; }
    .stat-donut-slot-big { margin: 0; z-index: 1; }
</style>
