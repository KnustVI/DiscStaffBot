<!--
  web/views/partials/stat-donut.ejs
  Card de gráfico donut (spec Figma exata: "Donut Graphic"/"Frame 11936" —
  um círculo maior que o próprio card, recortado por overflow:hidden, com
  um disco escuro (track) por baixo e um conic-gradient colorido (fill) por
  cima preenchendo X%). O Figma usa uma Ellipse nativa com propriedade de
  arco (não exportável em CSS puro — "Copy CSS" só traz os dois círculos
  cheios sobrepostos); conic-gradient é o jeito certo de recriar isso em
  CSS de um jeito que realmente varia com o percentual real, em vez de fixo.

  Uso (sem os delimitadores reais de tag do EJS de propósito — ver aviso
  em sidebar-v2.ejs sobre por que um deles de verdade aqui dentro quebraria
  a página):
    include( partials/stat-donut , {
      title: Jogadores Online ,
      value: 12/40 ,             // texto mostrado no centro do gráfico
      percent: 30,                // 0-100, preenchimento do arco
      accent: gold ,              // gold (#DCA15E, padrão) ou red (#803E30, --surface)
      size: big ,                 // opcional — 'big' pro donut maior/destaque (Figma: ~1.27x), omitir pro tamanho normal
    } )
-->
<%
    const dTitle = title;
    const dValue = value;
    const dPercent = Math.max(0, Math.min(100, Number(percent) || 0));
    const dAccent = typeof accent !== 'undefined' && accent === 'red' ? 'red' : 'gold';
    const dColor = dAccent === 'red' ? '#803E30' : '#DCA15E';
    const dBig = typeof size !== 'undefined' && size === 'big';
%>
<div class="stat-donut-frame<%= dBig ? ' is-big' : '' %>">
    <div class="stat-donut-circle">
        <div class="stat-donut-track" style="box-shadow: 0px 0px 2.3px <%= dColor %>, 12px 15px 11.5px rgba(0, 0, 0, 0.36), inset 0px 4px 4px rgba(0, 0, 0, 0.25);"></div>
        <div class="stat-donut-fill" style="background: conic-gradient(<%= dColor %> <%= dPercent.toFixed(1) %>%, transparent 0);"></div>
    </div>
    <div class="stat-donut-label">
        <span class="stat-donut-title"><%= dTitle %></span>
        <span class="stat-donut-value"><%= dValue %></span>
    </div>
</div>
<style>
    /* Tamanhos responsivos (clamp) em vez dos 224x241/282x307 fixos do
       Figma — padrão do site é sempre funcionar em mobile (ver
       web_ui_always_responsive). Mesma proporção ~1.27x entre normal/big
       do Figma (282/224), e mesma proporção altura:largura de cada um
       (241/224 ≈ 1.076 / 307/282 ≈ 1.089). */
    .stat-donut-frame {
        position: relative;
        flex: none;
        width: clamp(120px, 15vw, 170px);
        height: clamp(129px, 16.14vw, 183px);
        overflow: hidden;
        border-radius: 20px;
        margin: 0 -18px;
    }
    .stat-donut-frame.is-big {
        width: clamp(150px, 19vw, 216px);
        height: clamp(163px, 20.7vw, 235px);
        margin: 0 -12px;
        z-index: 1;
    }
    /* Círculo maior que o próprio frame (125%/127% de largura, altura
       travada em 1:1 via aspect-ratio — o frame NÃO é quadrado, então
       height% sozinho não daria um círculo de verdade) e deslocado pro
       canto superior esquerdo (~2-3%), igual ao left:6px/top:8px do Figma
       — é esse deslocamento que cria o recorte em formato de arco. */
    .stat-donut-circle {
        position: absolute;
        width: 125%;
        aspect-ratio: 1 / 1;
        left: 2.7%;
        top: 3.3%;
    }
    .stat-donut-frame.is-big .stat-donut-circle { width: 127%; left: 2.1%; top: 2.6%; }
    .stat-donut-track, .stat-donut-fill {
        position: absolute;
        inset: 0;
        border-radius: 50%;
    }
    .stat-donut-track { background: rgba(62, 61, 56, 0.2); }
    .stat-donut-label {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        text-align: center;
        padding: 0 10px;
        pointer-events: none;
    }
    .stat-donut-title, .stat-donut-value {
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: clamp(13px, 1.4vw, 20px);
        line-height: 1.3;
        color: #F8DCC0;
    }
</style>
