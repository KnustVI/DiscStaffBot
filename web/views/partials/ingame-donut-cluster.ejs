<%#
  web/views/partials/ingame-donut-cluster.ejs
  Composição EXATA dos 3 donuts do painel "IN GAME" (Figma: Frame 11936,
  canvas compartilhado 770x307) — geometria (centro/raio/janela de cada
  anel) extraída do SVG que o dono exportou do Figma, verificada de novo
  por leitura completa + conferência adversarial do Moderação.txt.

  Recorte de cada janela usa um <svg> ANINHADO por donut, com viewBox
  deslocado pra dentro do MESMO sistema de coordenadas absoluto (não um
  clip-path por cima de tudo) — um clip-path num <g> que também tem
  filter aplicado NÃO recorta de verdade em todo renderizador (confirmado
  rasterizando e conferindo visualmente: o recorte simplesmente não
  acontecia, os 3 anéis apareciam como círculos inteiros descobertos, se
  sobrepondo muito além da janela pequena esperada). Viewport de <svg> é
  clipagem nativa, muito mais confiável — cada janela vira seu próprio
  <svg viewBox="winX winY winW winH">, então os paths (definidos nas
  coordenadas absolutas do canvas 770x307) caem no lugar certo sozinhos,
  sem precisar traduzir nada. Cantos arredondados (20px) ficam por conta
  do container HTML (overflow:hidden + border-radius), não do SVG.

  NÃO troque os centros/raios/janelas dos 3 anéis sem um novo export do
  Figma — confirmados pixel a pixel duas vezes. NÃO volte a usar
  clip-path num <g> com filter sem testar de novo primeiro (ver aviso
  acima).

  Uso: include( partials/ingame-donut-cluster , { donuts, clusterId } ) —
  donuts é um array de EXATAMENTE 3 objetos { title, value, percent,
  accent }, na ordem [pequeno-esquerda, pequeno-meio, grande-direita] (a
  posição de cada um no canvas é fixa). clusterId é opcional (default
  'ingame') — só importa se dois clusters aparecerem na mesma página.
%>
<%
    const RINGS = [
        { cx: 196, cy: 214, rOuter: 140, rInner: 98, win: { x: 50, y: 66, w: 224, h: 241 } },
        { cx: 390, cy: 214, rOuter: 140, rInner: 98, win: { x: 244, y: 66, w: 224, h: 241 } },
        { cx: 623, cy: 187, rOuter: 179, rInner: 125.3, win: { x: 438, y: 0, w: 282, h: 307 } },
    ];
    const CANVAS_W = 770, CANVAS_H = 307;
    const idcClusterId = (typeof clusterId !== 'undefined' && clusterId) ? String(clusterId).replace(/[^a-zA-Z0-9_-]/g, '') : 'ingame';

    function circlePath(cx, cy, r) {
        return `M ${cx + r},${cy} A ${r},${r} 0 0,1 ${cx},${cy + r} A ${r},${r} 0 0,1 ${cx - r},${cy} A ${r},${r} 0 0,1 ${cx},${cy - r} A ${r},${r} 0 0,1 ${cx + r},${cy} Z`;
    }
    function ringPath(cx, cy, rOuter, rInner) {
        return `${circlePath(cx, cy, rOuter)} ${circlePath(cx, cy, rInner)}`;
    }
    function wedgePath(cx, cy, rOuter, percent) {
        const p = Math.max(0, Math.min(100, Number(percent) || 0));
        if (p <= 0) return null;
        const RW = rOuter + 20;
        if (p >= 100) return circlePath(cx, cy, RW);
        const sweep = (p / 100) * 360;
        const toRad = (deg) => (deg * Math.PI) / 180;
        const start = { x: (cx + RW * Math.cos(toRad(-90))).toFixed(2), y: (cy + RW * Math.sin(toRad(-90))).toFixed(2) };
        const end = { x: (cx + RW * Math.cos(toRad(-90 + sweep))).toFixed(2), y: (cy + RW * Math.sin(toRad(-90 + sweep))).toFixed(2) };
        const largeArc = sweep > 180 ? 1 : 0;
        return `M ${cx},${cy} L ${start.x},${start.y} A ${RW},${RW} 0 ${largeArc},1 ${end.x},${end.y} Z`;
    }
    function accentHex(accent) { return accent === 'red' ? '#803E30' : '#DCA15E'; }
%>
<div class="idc-root">
    <% RINGS.forEach((r, i) => {
        const hex = accentHex(donuts[i].accent);
        const wedge = wedgePath(r.cx, r.cy, r.rOuter, donuts[i].percent);
        const ring = ringPath(r.cx, r.cy, r.rOuter, r.rInner);
        const leftPct = (r.win.x / CANVAS_W) * 100;
        const topPct = (r.win.y / CANVAS_H) * 100;
        const winWPct = (r.win.w / CANVAS_W) * 100;
        const winHPct = (r.win.h / CANVAS_H) * 100;
        const labelLeftPct = ((r.cx - r.win.x) / r.win.w) * 100;
        const labelTopPct = ((r.cy - r.win.y) / r.win.h) * 100;
        const labelWidthPct = ((r.rInner * 1.9) / r.win.w) * 100;
    %>
        <%# z-order: quem está mais à direita vem DEPOIS no HTML, então
            fica na frente de quem está à esquerda onde as janelas se
            sobrepõem (pedido do dono) — RINGS já está na ordem
            esquerda->direita, então o forEach cuida disso sozinho. %>
        <div class="idc-window" style="left: <%= leftPct.toFixed(2) %>%; top: <%= topPct.toFixed(2) %>%; width: <%= winWPct.toFixed(2) %>%; height: <%= winHPct.toFixed(2) %>%;">
            <svg class="idc-svg" viewBox="<%= r.win.x %> <%= r.win.y %> <%= r.win.w %> <%= r.win.h %>" overflow="hidden" style="overflow: hidden;" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <filter id="idc-glow-<%= idcClusterId %>-<%= i %>" x="-30%" y="-20%" width="160%" height="150%" filterUnits="objectBoundingBox" color-interpolation-filters="sRGB">
                        <feDropShadow dx="12" dy="15" stdDeviation="5.75" flood-color="#000000" flood-opacity="0.36" in="SourceGraphic" result="idc-shadow1-<%= idcClusterId %>-<%= i %>"/>
                        <feDropShadow dx="0" dy="0" stdDeviation="1.15" flood-color="<%= hex %>" flood-opacity="1" in="idc-shadow1-<%= idcClusterId %>-<%= i %>"/>
                    </filter>
                    <% if (wedge) { %>
                        <clipPath id="idc-wedge-<%= idcClusterId %>-<%= i %>"><path d="<%= wedge %>"/></clipPath>
                    <% } %>
                </defs>
                <g filter="url(#idc-glow-<%= idcClusterId %>-<%= i %>)">
                    <path d="<%= ring %>" fill-rule="evenodd" fill="#3E3D38" fill-opacity="0.2"/>
                </g>
                <% if (wedge) { %>
                    <g clip-path="url(#idc-wedge-<%= idcClusterId %>-<%= i %>)">
                        <path d="<%= ring %>" fill-rule="evenodd" fill="<%= hex %>"/>
                    </g>
                <% } %>
            </svg>
            <div class="idc-label" style="left: <%= labelLeftPct.toFixed(2) %>%; top: <%= labelTopPct.toFixed(2) %>%; width: <%= labelWidthPct.toFixed(2) %>%;">
                <span class="idc-title"><%= donuts[i].title %></span>
                <span class="idc-value"><%= donuts[i].value %></span>
            </div>
        </div>
    <% }); %>
</div>
<style>
    .idc-root {
        position: relative;
        width: 100%;
        max-width: 770px;
        aspect-ratio: 770 / 307;
        margin-left: auto; /* Figma: cluster encostado na direita do card (Frame 3, justify-content:flex-end) */
    }
    .idc-window { position: absolute; }
    .idc-svg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        overflow: hidden; /* clipagem real: viewport do SVG, não clip-path */
        border-radius: 20px; /* cosmético (a maioria dos navegadores já corta certo pelo viewBox, isso só arredonda a borda visível) */
    }
    .idc-label {
        position: absolute;
        transform: translate(-50%, -50%);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3px;
        text-align: center;
        pointer-events: none;
    }
    .idc-title, .idc-value {
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: clamp(10px, 1.3vw, 14px);
        line-height: 1.25;
        color: #F8DCC0;
    }
</style>
