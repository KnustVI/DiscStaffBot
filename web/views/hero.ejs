        <thead>
            <tr>
                <th style="border:none;"></th>
                <th>FREE</th>
                <th style="color:#DCA15E;">RASTREADOR<br><span style="font-family:'Poppins',sans-serif; font-size:12px; text-transform:none; opacity:0.7;" data-i18n-pt>Tudo do Free +</span><span style="font-family:'Poppins',sans-serif; font-size:12px; text-transform:none; opacity:0.7;" data-i18n-en>Everything in Free +</span></th>
                <th style="color:#FF4E3B;">CAÇADOR<br><span style="font-family:'Poppins',sans-serif; font-size:12px; text-transform:none; opacity:0.7;" data-i18n-pt>Tudo do Rastreador +</span><span style="font-family:'Poppins',sans-serif; font-size:12px; text-transform:none; opacity:0.7;" data-i18n-en>Everything in Rastreador +</span></th>
            </tr>
        </thead>
        <tbody>
            <%
            const rows = [
                { labelPt: 'MISSÕES', labelEn: 'MISSIONS',
                  free: { pt: "Missões mensais do Titan's Pass (em breve).", en: "Titan's Pass monthly missions (coming soon)." },
                  rast: { pt: '1 missão mensal exclusiva para o servidor (em breve). Badge exclusiva para players (em breve).', en: '1 monthly mission exclusive to the server (coming soon). Exclusive badge for players (coming soon).' },
                  cac: { pt: '2 missões mensais exclusivas para o servidor (em breve).', en: '2 monthly missions exclusive to the server (coming soon).' } },
                { labelPt: 'REPORTES', labelEn: 'REPORTS',
                  free: { pt: 'Até 1 chat de reporte ativo. Até 1 revisão de punição ativa. Cooldown de 6h.', en: 'Up to 1 active report chat. Up to 1 active punishment review. 6h cooldown.' },
                  rast: { pt: 'Até 3 chats de reporte ativos. Até 3 revisões de punição ativas. Sem tempo de espera.', en: 'Up to 3 active report chats. Up to 3 active punishment reviews. No cooldown.' },
                  cac: { pt: 'Chats de reporte ilimitados, sem tempo de espera. Resumo automático dos logs dos possíveis envolvidos direto no chat (em breve). Personalização de banners e mensagem do painel.', en: 'Unlimited report chats, no cooldown. Automatic summary of involved players\' logs right in the chat (coming soon). Banner and panel message customization.' } },
                { labelPt: 'MODERAÇÃO', labelEn: 'MODERATION',
                  free: { pt: 'Registro de punições.', en: 'Punishment logging.' },
                  rast: { pt: 'Sistema de pontos de reputação. Cargo temporário de punição. Até 4 níveis de punição configuráveis. Histórico de punições.', en: 'Reputation point system. Temporary punishment role. Up to 4 configurable punishment levels. Punishment history.' },
                  cac: { pt: 'Cargo temporário de punição. Até 10 níveis de punição configuráveis. Personalização de qual comando requer supervisão. Cargos de reputação automáticos. Análise de atividade de staff.', en: 'Temporary punishment role. Up to 10 configurable punishment levels. Customize which command requires supervisor approval. Automatic reputation roles. Staff activity analysis.' } },
                { labelPt: 'EVENTOS', labelEn: 'EVENTS',
                  free: { pt: 'Cria eventos em fóruns. Suporte para imagem de capa do evento.', en: 'Creates events in forums. Supports an event cover image.' },
                  rast: { pt: 'Cria eventos diretamente no Discord. Marca automaticamente jogadores com o cargo selecionado.', en: 'Creates events directly on Discord. Automatically pings players with the selected role.' },
                  cac: { pt: 'Anuncia automaticamente a criação, o início e o encerramento dos eventos. Faz postagem em redes sociais (em breve). Análise de atividade de staff.', en: 'Automatically announces event creation, start, and end. Posts to social media (coming soon). Staff activity analysis.' } },
                { labelPt: 'INTEGRAÇÃO PATH OF TITANS', labelEn: 'PATH OF TITANS INTEGRATION',
                  free: { pt: 'Logs de jogo por webhook.', en: 'In-game logs via webhook.' },
                  rast: { pt: 'Ação automática em jogo (RCON) nas punições. Aviso automático em jogo antes de eventos. Botões de teleporte configuráveis.', en: 'Automatic in-game action (RCON) on punishments. Automatic in-game event reminders. Configurable teleport buttons.' },
                  cac: { pt: 'Todos os comandos disponíveis para aplicar in-game via RCON. Comando de TP integrado à criação de eventos. Criar comando de buff personalizado. Postagem automática de ninhos (em breve). Mute automático in-game com filtro personalizado de palavras.', en: 'Every command available to apply in-game via RCON. TP command integrated into event creation. Create a custom buff command. Automatic nest posting (coming soon). Automatic in-game mute with a custom word filter.' } },
                { labelPt: 'BONUS', labelEn: 'BONUS',
                  free: { pt: '—', en: '—' },
                  rast: { pt: 'O proprietário do servidor recebe Player Premium Compy gratuitamente.', en: 'The server owner gets Player Premium Compy for free.' },
                  cac: { pt: 'O proprietário do servidor recebe Player Premium Raptor gratuitamente. Personalização de banners, cores e rodapé dos painéis.', en: 'The server owner gets Player Premium Raptor for free. Banner, color, and panel footer customization.' } },
            ];
            %>
            <% rows.forEach(r => { %>
                <tr>
                    <td class="label"><span data-i18n-pt><%= r.labelPt %></span><span data-i18n-en><%= r.labelEn %></span></td>
                    <td><span data-i18n-pt><%= r.free.pt %></span><span data-i18n-en><%= r.free.en %></span></td>
                    <td><span data-i18n-pt><%= r.rast.pt %></span><span data-i18n-en><%= r.rast.en %></span></td>
                    <td><span data-i18n-pt><%= r.cac.pt %></span><span data-i18n-en><%= r.cac.en %></span></td>
