                <td class="cmp-price" style="color:#FF4E3B;">R$40<span style="font-size:14px;">/<span data-i18n-pt>mês</span><span data-i18n-en>mo</span></span></td>
            </tr>
        </tbody>
    </table>
    </div>
</section>

<!-- ===================== PORQUE USAR ===================== -->
<section class="w-full flex flex-col items-center" style="background:#111111; padding: 60px 16px;">
    <h2 class="section-title text-shadow-figma mb-10 text-center"><span data-i18n-pt>PORQUE USAR?</span><span data-i18n-en>WHY USE IT?</span></h2>
    <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-10" style="max-width: 1100px;">
        <%
        const why = [
            { icon: '<path d="M12 3v14"/><path d="m6 11 6 6 6-6"/><path d="M5 21h14"/>', pt: 'Reduza tarefas repetitivas com sistemas automatizados que ajudam a manter a comunidade organizada, permitindo que a equipe foque no que realmente importa.',
