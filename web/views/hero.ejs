        %>
        <% why.forEach(w => { %>
            <div class="flex flex-col items-center text-center gap-4">
                <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#F8DCC0" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><%- w.icon %></svg>
                <p style="font-family:'Poppins',sans-serif; font-size:16px; opacity:0.9;" class="text-shadow-figma">
                    <span data-i18n-pt><%= w.pt %></span><span data-i18n-en><%= w.en %></span>
                </p>
            </div>
        <% }); %>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-4 mt-12">
        <a href="https://discord.com/oauth2/authorize?client_id=<%= bot.user.id %>&permissions=8&scope=bot%20applications.commands" class="btn-primary" target="_blank" rel="noopener">
            <span data-i18n-pt>CONVIDE O BOT</span><span data-i18n-en>INVITE THE BOT</span>
        </a>
        <a href="/dashboard" class="btn-primary">
            <span data-i18n-pt>DASHBOARD</span><span data-i18n-en>DASHBOARD</span>
        </a>
    </div>
