</div>
<section id="premium" class="relative w-full flex flex-col items-center" style="padding: 60px 16px;">
    <h2 class="section-title text-shadow-figma mb-2 text-center"><span data-i18n-pt>PLAYER PREMIUM</span><span data-i18n-en>PLAYER PREMIUM</span></h2>
    <p class="mb-4 text-center opacity-90 text-shadow-figma" style="font-family:'Poppins',sans-serif; font-weight:600;">
        <span data-i18n-pt>Personalize seu perfil e participe das missões mensais do bot!</span>
        <span data-i18n-en>Customize your profile and take part in the bot's monthly missions!</span>
    </p>
    <%
    // Preço/pagamento variam por região (isBrazil, ver dashboard.js): Brasil
    // continua 100% manual via Pix (como hoje), fora do Brasil vai por
    // Ko-fi em US$ — pedido do dono, PayPal direto exigiria conta Empresa
    // com CNPJ que ele não tem. O idioma exibido continua controlado pelo
    // toggle EN/PT normal (data-i18n-*), independente da região.
    //
    // BR não tem mais botão por card: todo tier pago de uma mesma seção
    // leva pro MESMO link (servidor de suporte), então em vez de repetir
    // "Assinar" em cada card, um botão só (acquireSectionButton, abaixo)
    // cobre a seção inteira. Ko-fi (fora do Brasil) continua por card —
    // implementação separada, ainda não revisada.
    function pricingCta(priceBR, priceIntl, color) {
        const moneyLine = `<p class="text-2xl font-bold my-2" style="font-family:'Tilt Warp',sans-serif; color:${color};">${isBrazil ? priceBR : priceIntl}<span class="text-sm opacity-70">/<span data-i18n-pt>mês</span><span data-i18n-en>mo</span></span></p>`;
        const ctaLine = isBrazil
            ? `<p class="text-xs opacity-70 mb-3" style="font-family:'Poppins',sans-serif;"><span data-i18n-pt>Pagamento manual via Pix — fale com a staff.</span><span data-i18n-en>Manual payment via Pix — talk to the staff.</span></p>`
            : `<a href="https://ko-fi.com/knustvi" target="_blank" rel="noopener" class="btn-primary small" style="min-width:0; margin-bottom:12px;"><span data-i18n-pt>Assinar via Ko-fi</span><span data-i18n-en>Subscribe via Ko-fi</span></a>`;
        return moneyLine + ctaLine;
    }

    // Botão único por seção (só BR — Ko-fi já resolve isso por card, um
    // link por tier). Mesmo link de suporte usado em todo o resto do site.
    function acquireSectionButton(labelPt, labelEn) {
        if (!isBrazil) return '';
        return `<a href="https://discord.gg/fkD5FQktn6" target="_blank" rel="noopener" class="btn-primary small mb-6" style="min-width:0; height:32px; font-size:13px; padding:5px 18px;">💎 <span data-i18n-pt>${labelPt}</span><span data-i18n-en>${labelEn}</span></a>`;
    }
    %>
    <%- acquireSectionButton('Adquirir Player Premium', 'Get Player Premium') %>
    <div class="w-full grid grid-cols-1 md:grid-cols-3 gap-6" style="max-width: 1000px;">
        <div class="pricing-card">
            <h3 style="font-family:'Tilt Warp',sans-serif; font-size:24px; text-transform:uppercase;">FREE</h3>
            <ul style="font-family:'Poppins',sans-serif; font-size:14px; display:flex; flex-direction:column; gap:8px; list-style:none; padding:0; opacity:0.9; margin-top:12px;">
                <li><span data-i18n-pt>Perfil sincronizado com o Discord</span><span data-i18n-en>Profile synced with Discord</span></li>
                <li><span data-i18n-pt>Badges de missões</span><span data-i18n-en>Mission badges</span></li>
                <li><span data-i18n-pt>Títulos de missões</span><span data-i18n-en>Mission titles</span></li>
                <li><span data-i18n-pt>Ganhe Hunt por hora de jogo</span><span data-i18n-en>Earn Hunt per hour played</span></li>
            </ul>
        </div>
        <div class="pricing-card featured">
            <h3 style="font-family:'Tilt Warp',sans-serif; font-size:24px; text-transform:uppercase; color:#DCA15E;">COMPY</h3>
            <%- pricingCta('R$10', '$6', '#DCA15E') %>
            <p class="text-xs opacity-60 mb-2" style="font-family:'Poppins',sans-serif;"><span data-i18n-pt>Tudo do Free +</span><span data-i18n-en>Everything in Free +</span></p>
            <ul style="font-family:'Poppins',sans-serif; font-size:14px; display:flex; flex-direction:column; gap:8px; list-style:none; padding:0; opacity:0.9;">
                <li><span data-i18n-pt>Perfil personalizável pela loja</span><span data-i18n-en>Store-customizable profile</span></li>
                <li><span data-i18n-pt>Badge exclusivo</span><span data-i18n-en>Exclusive badge</span></li>
                <li><span data-i18n-pt>Títulos exclusivos</span><span data-i18n-en>Exclusive titles</span></li>
                <li><span data-i18n-pt>Ganho extra de Hunt por troféu entregue</span><span data-i18n-en>Extra Hunt earnings per trophy delivered</span></li>
            </ul>
        </div>
        <div class="pricing-card">
            <h3 style="font-family:'Tilt Warp',sans-serif; font-size:24px; text-transform:uppercase; color:#FF4E3B;">RAPTOR</h3>
            <%- pricingCta('R$25', '$12', '#FF4E3B') %>
            <p class="text-xs opacity-60 mb-2" style="font-family:'Poppins',sans-serif;"><span data-i18n-pt>Tudo do Compy +</span><span data-i18n-en>Everything in Compy +</span></p>
            <ul style="font-family:'Poppins',sans-serif; font-size:14px; display:flex; flex-direction:column; gap:8px; list-style:none; padding:0; opacity:0.9;">
                <li><span data-i18n-pt>Perfil 100% personalizável com suas próprias imagens</span><span data-i18n-en>100% custom profile with your own images</span></li>
                <li><span data-i18n-pt>Ganho extra de Hunt por missão Titan concluída</span><span data-i18n-en>Extra Hunt earnings per completed Titan mission</span></li>
                <li><span data-i18n-pt>Sorteio mensal de pacote de skins do POT</span><span data-i18n-en>Monthly PoT skin package giveaway</span></li>
            </ul>
        </div>
    </div>
</section>

<!-- ===================== SERVER PREMIUM ===================== -->
<div class="relative w-full flex justify-center" style="padding: 0 16px;">
    <div style="width:100%; max-width:1100px; border-top:1px solid #3E3D38;"></div>
</div>
<section class="relative w-full flex flex-col items-center" style="padding: 20px 16px 70px;">
    <h2 class="section-title text-shadow-figma mb-2 text-center"><span data-i18n-pt>SERVER PREMIUM</span><span data-i18n-en>SERVER PREMIUM</span></h2>
    <p class="mb-4 text-center opacity-90 text-shadow-figma" style="font-family:'Poppins',sans-serif; font-weight:600;">
        <span data-i18n-pt>Melhore tudo que puder no seu servidor!</span>
        <span data-i18n-en>Level up everything you can on your server!</span>
