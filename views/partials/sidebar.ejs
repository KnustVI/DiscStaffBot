<div class="flex flex-col h-full w-full titan-card-premium p-6 overflow-hidden">
    <!-- LOGO -->
    <div class="flex flex-col items-center mb-10 pt-4">
        <img src="https://i.ibb.co/whjd7DYJ/Titans-pass-logo.png" alt="Logo" class="w-20 mb-3 drop-shadow-[0_0_15px_rgba(217,163,98,0.4)] transition-transform hover:scale-110 duration-500">
        <h2 class="tilt-warp text-titan-gold text-lg tracking-[3px] uppercase">Titan's Pass</h2>
        <div class="w-8 h-[1px] bg-titan-accent/50 mt-1"></div>
    </div>

    <!-- NAVEGAÇÃO -->
    <nav class="flex-1 space-y-3">
        <p class="text-[9px] uppercase tracking-[4px] opacity-20 font-bold ml-2 mb-4">Dashboard</p>
        
        <a href="/home/<%= guild.id %>" class="flex items-center gap-4 px-4 py-3 rounded-xl bg-[#803E30]/10 border border-[#803E30]/30 text-titan-cream transition-all hover:bg-[#803E30]/20 group">
            <svg class="w-5 h-5 opacity-70 group-hover:text-titan-gold transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
            <span class="text-[11px] font-bold uppercase tracking-widest">Início</span>
        </a>

        <a href="/manage/<%= guild.id %>" class="flex items-center gap-4 px-4 py-3 rounded-xl text-titan-cream/40 transition-all hover:bg-white/5 hover:text-titan-cream group">
            <svg class="w-5 h-5 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path></svg>
            <span class="text-[11px] font-bold uppercase tracking-widest">Ajustes</span>
        </a>
    </nav>

    <!-- CARD DO PERFIL -->
    <div class="mt-auto pt-6 border-t border-white/5">
        <div class="flex flex-col gap-3 p-3 bg-black/20 rounded-2xl border border-white/5 shadow-inner">
            <div class="flex items-center gap-3">
                <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-10 h-10 rounded-xl border border-titan-gold/30">
                <div class="overflow-hidden">
                    <p class="text-[11px] font-bold text-titan-cream truncate uppercase"><%= nickname %></p>
                    <p class="text-[9px] text-titan-accent font-black uppercase tracking-tighter truncate"><%= role %></p>
                </div>
            </div>
            <div class="flex justify-between items-center px-1">
                <span class="text-[8px] text-titan-gold/60 font-bold uppercase">NV. <%= level %></span>
                <span class="text-[8px] text-titan-gold/60 font-bold uppercase">REP. <%= reputation %></span>
            </div>
        </div>
        
        <a href="/logout" class="flex items-center justify-center gap-2 mt-4 text-[9px] text-red-500/30 hover:text-red-500 transition-all uppercase font-bold tracking-[3px]">
            Sair
        </a>
    </div>
</div>