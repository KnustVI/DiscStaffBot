<!-- Container Principal da Sidebar com suas medidas exatas -->
<div class="flex flex-col w-[446px] items-center justify-between px-[30px] py-5 relative self-stretch titan-card-premium shadow-[-25px_47px_68.1px_#000000bd,0.5px_-0.5px_0.5px_#f8dcc0]">
    
    <!-- Seção da Logo -->
    <div class="flex flex-col w-[344px] h-[243px] items-start gap-2 px-0 py-2.5 relative">
        <img 
            class="relative self-stretch w-full h-[237.84px] mb-[-14.84px] object-cover transition-transform hover:scale-105 duration-700"
            alt="Titans pass logo"
            src="https://c.animaapp.com/mnb8jqp9dw8rx4/img/titans-pass-logo-1.png"
        />
        
        <!-- Opcional: Nome do Bot caso queira abaixo da logo gigante -->
        <!-- <h2 class="tilt-warp text-titan-gold text-2xl tracking-[4px] uppercase self-center">Titan's Pass</h2> -->
    </div>

        <!-- Navigation Menu -->
        <nav class="inline-flex flex-col items-start gap-3 relative flex-[0_0_auto] w-full px-4 overflow-y-auto max-h-[500px] custom-scrollbar">
            
            <% 
            const navItems = [
                { label: "CONFIGURAÇÕES", path: "manage" },
                { label: "IN GAME", path: "ingame" },
                { label: "TICKETS", path: "tickets" },
                { label: "STAFFS", path: "staffs" },
                { label: "STRIKES", path: "strikes" },
                { label: "PERFIL", path: "profile" }
            ];
            %>

            <% navItems.forEach(item => { %>
                <a href="/<%= item.path %>/<%= guild.id %>" 
                class="flex w-full max-w-[332px] h-[49px] shrink-0 items-center justify-center gap-2 px-2.5 py-[9px] relative rounded-[15px] border-2 border-solid border-[#803e30] shadow-[0px_12px_19.5px_2px_#01020a7d] transition-all cursor-pointer group <%= (typeof path !== 'undefined' && path === item.path) ? 'bg-[#3a2020]' : 'bg-[#292929]' %> hover:bg-[#3a2020] hover:scale-[1.02]">
                    
                    <span class="relative flex items-center justify-center w-[308px] h-[37px] mt-[-5.00px] mb-[-1.00px] [font-family:'Poppins',Helvetica] font-normal text-[#f8dcc0] text-xl text-center tracking-[0] leading-[normal] uppercase group-hover:text-white transition-colors">
                        <%= item.label %>
                    </span>
                </a>
            <% }); %>

        </nav>

        <style>
            /* Estilização da barra de rolagem para não quebrar o visual premium */
            .custom-scrollbar::-webkit-scrollbar {
                width: 4px;
            }
            .custom-scrollbar::-webkit-scrollbar-track {
                background: transparent;
            }
            .custom-scrollbar::-webkit-scrollbar-thumb {
                background: #803e30;
                border-radius: 10px;
            }
        </style>

            <!-- User Profile Section (Baseado no seu design exato) -->
        <div class="mt-auto pt-8 border-t border-white/5 flex flex-col items-center justify-center gap-3 px-0 py-2.5 relative self-stretch w-full flex-[0_0_auto]">
            
            <!-- Avatar Placeholder / Real Avatar -->
            <div class="inline-flex items-center gap-2 relative flex-[0_0_auto]">
                <div class="relative w-[110px] h-28 rounded-[147.5px] border-2 border-solid border-[#803e30] shadow-[0px_12px_18px_11px_#01020a73] overflow-hidden">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" 
                        alt="Avatar" 
                        class="w-full h-full object-cover bg-[#292929]">
                </div>
            </div>

            <!-- Nickname and role -->
            <div class="inline-flex flex-col items-center justify-center gap-3 relative flex-[0_0_auto]">
                <div class="inline-flex items-center justify-center gap-2 relative flex-[0_0_auto]">
                    <span class="relative flex items-center justify-center w-[146px] h-[38px] mt-[-1.00px] [font-family:'Tilt_Warp',Helvetica] font-normal text-[#f8dcc0] text-2xl text-center tracking-[0] leading-[normal] uppercase">
                        <%= nickname %>
                    </span>
                </div>

                <!-- Cargo Badge -->
                <div class="flex w-[136px] h-[26px] items-center justify-center gap-2 p1-2.5 pr-[11px] py-[5px] relative bg-[#4b2427] rounded-[30px] border border-solid border-[#f8dcc0] shadow-[0px_12px_18.6px_4px_#01020a70]">
                    <span class="relative w-[143.02px] h-[21.07px] mt-[-3.54px] mb-[-1.54px] ml-[-14.01px] mr-[-14.01px] [font-family:'Bebas_Neue',Helvetica] font-normal text-[#f8dcc0] text-xl text-center tracking-[0] leading-[normal] whitespace-nowrap uppercase">
                        <%= role %>
                    </span>
                </div>
            </div>

            <!-- Botão de Sair (Opcional, discreto abaixo do perfil) -->
            <a href="/logout" class="mt-2 text-[10px] text-red-500/20 hover:text-red-500/80 transition-colors uppercase tracking-[3px] font-bold">
                Sair
            </a>
        </div>
        
        <a href="/logout" class="flex items-center justify-center gap-2 mt-4 text-[9px] text-red-500/30 hover:text-red-500 transition-all uppercase font-bold tracking-[3px]">
            Sair
        </a>
    </div>
</div>