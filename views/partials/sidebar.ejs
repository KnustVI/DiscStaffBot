<!-- O Container Principal (Equivalente ao seu .v27_84) -->
<div class="flex flex-col w-[320px] h-[calc(100vh-2rem)] bg-[#1F1D20] rounded-[20px] border border-white/5 shadow-[25px_47px_68px_rgba(0,0,0,0.74)] overflow-hidden">
    
    <!-- ÁREA DO LOGO (Equivalente ao v27_119 / v27_85) -->
    <div class="relative w-full h-[220px] flex items-center justify-center p-6">
        <!-- Círculo de brilho atrás do logo para dar profundidade -->
        <div class="absolute w-32 h-32 bg-[#803E30]/20 blur-[40px] rounded-full"></div>
        <img src="/img/logo.png" class="relative z-10 w-48 drop-shadow-2xl" alt="Logo">
    </div>

    <!-- MENU DE NAVEGAÇÃO (Substituindo os nomes vazios do v27_118) -->
    <nav class="flex-1 px-6 space-y-3">
        <p class="text-[10px] uppercase tracking-[4px] text-[#F8DCC0]/30 font-bold mb-4">Navegação</p>
        
        <a href="/home/<%= guild.id %>" class="flex items-center gap-3 p-3 rounded-xl bg-[#803E30]/10 border border-[#803E30]/30 text-[#F8DCC0] hover:bg-[#803E30]/20 transition-all group">
            <div class="w-1.5 h-1.5 rounded-full bg-[#D9A362] shadow-[0_0_8px_#D9A362]"></div>
            <span class="text-sm font-semibold uppercase tracking-wider">Início</span>
        </a>

        <a href="/manage/<%= guild.id %>" class="flex items-center gap-3 p-3 rounded-xl text-[#F8DCC0]/60 hover:text-[#F8DCC0] hover:bg-white/5 transition-all">
            <div class="w-1.5 h-1.5 rounded-full bg-white/10"></div>
            <span class="text-sm font-semibold uppercase tracking-wider">Configurações</span>
        </a>

        <a href="#" class="flex items-center gap-3 p-3 rounded-xl text-[#F8DCC0]/60 hover:text-[#F8DCC0] hover:bg-white/5 transition-all">
            <div class="w-1.5 h-1.5 rounded-full bg-white/10"></div>
            <span class="text-sm font-semibold uppercase tracking-wider">Tickets</span>
        </a>
    </nav>

    <!-- CARD DO PERFIL (Equivalente ao v27_104 / v27_122 / v27_123) -->
    <div class="p-4 bg-[#131314]/80 border-t border-white/5">
        <div class="flex items-center gap-4">
            
            <!-- AVATAR (v27_105) -->
            <div class="relative w-16 h-16 shrink-0">
                <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" 
                     class="w-full h-full rounded-full border-2 border-[#803E30] shadow-[0_12px_18px_rgba(0,0,0,0.45)] object-cover">
            </div>

            <!-- INFOS (v27_123) -->
            <div class="flex flex-col min-w-0">
                <!-- NICKNAME (v27_106) -->
                <span class="text-[#F8DCC0] font-['Tilt_Warp'] text-lg leading-tight truncate uppercase">
                    <%= nickname %>
                </span>
                
                <!-- CARGO (v27_107 / v27_109) -->
                <div class="mt-1 px-3 py-1 bg-[#4B2427] rounded-full shadow-[0_12px_18px_rgba(0,0,0,0.44)] inline-block w-fit max-w-full">
                    <span class="text-[#F8DCC0] font-['Bebas_Neue'] text-xs tracking-widest uppercase truncate block">
                        <%= role %>
                    </span>
                </div>
            </div>
        </div>

        <!-- STATS RÁPIDOS (NV e REP) -->
        <div class="flex gap-2 mt-4">
            <div class="flex-1 bg-white/5 rounded-lg py-1 text-center border border-white/5">
                <p class="text-[8px] uppercase opacity-40">Nível</p>
                <p class="text-xs font-bold text-[#D9A362]"><%= level %></p>
            </div>
            <div class="flex-1 bg-white/5 rounded-lg py-1 text-center border border-white/5">
                <p class="text-[8px] uppercase opacity-40">Rep</p>
                <p class="text-xs font-bold text-[#D9A362]"><%= reputation %></p>
            </div>
        </div>
    </div>
</div>