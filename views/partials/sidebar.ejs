<!-- Sidebar com Auto Layout (justify-between garante o perfil sempre embaixo) -->
<aside class="flex flex-col w-[280px] h-screen items-center justify-between px-6 py-8 fixed left-0 top-0 z-50 titan-card-premium shadow-[-10px_0px_30px_rgba(0,0,0,0.5)]">
    
    <!-- TOP SECTION: Logo -->
    <div class="flex flex-col items-center w-full gap-2">
        <img 
            class="w-32 h-auto object-contain transition-transform hover:scale-105 duration-500"
            alt="Titans pass logo"
            src="https://c.animaapp.com/mnb8jqp9dw8rx4/img/titans-pass-logo-1.png"
        />
    </div>

    <!-- MIDDLE SECTION: Navigation Menu (Ocupa o espaço central) -->
    <nav class="flex flex-col items-center gap-3 w-full my-8 overflow-y-auto custom-scrollbar">
        <% 
        const navItems = [
            { label: "CONFIGURAÇÕES", path: "manage" },
            { label: "IN GAME", path: "ingame" },
            { label: "TICKETS", path: "tickets" },
            { label: "STAFFS", path: "staffs" },
            { label: "STRIKES", path: "strikes" },
            { label: "PERFIL", path: "profile" }
        ];
        %>

        <% navItems.forEach(item => { %>
            <a href="/<%= item.path %>/<%= guild.id %>" 
               class="flex w-full h-[42px] items-center justify-center rounded-[12px] border border-[#803e30]/50 shadow-md transition-all duration-300 group <%= (typeof path !== 'undefined' && path === item.path) ? 'bg-[#3a2020] border-[#f8dcc0]/30' : 'bg-[#292929]' %> hover:bg-[#3a2020]">
                
                <span class="[font-family:'Poppins',Helvetica] font-medium text-[#f8dcc0] text-sm tracking-widest uppercase">
                    <%= item.label %>
                </span>
            </a>
        <% }); %>
    </nav>

            <!-- BOTTOM SECTION: User Profile (Composição Horizontal) -->
        <div class="flex items-center w-full gap-4 pt-6 border-t border-white/5 px-2">
            
            <!-- Avatar (Lado Esquerdo) -->
            <div class="relative w-14 h-14 shrink-0 rounded-full border-2 border-[#803e30] shadow-[0px_4px_10px_rgba(0,0,0,0.5)] overflow-hidden">
                <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" 
                    alt="Avatar" class="w-full h-full object-cover">
            </div>

            <!-- Info (Lado Direito: Nickname + Cargo) -->
            <div class="flex flex-col items-start overflow-hidden">
                <span class="[font-family:'Tilt_Warp'] text-[#f8dcc0] text-base uppercase leading-tight truncate w-full">
                    <%= nickname %>
                </span>
                
                <!-- Badge de Cargo -->
                <div class="mt-1 px-3 py-0.5 bg-[#4b2427] rounded-full border border-[#f8dcc0]/50 shadow-sm">
                    <span class="[font-family:'Bebas_Neue'] text-[#f8dcc0] text-xs tracking-wider uppercase whitespace-nowrap">
                        <%= role %>
                    </span>
                </div>
            </div>

        </div>

        <!-- Logout (Link solitário abaixo da composição para manter o alinhamento) -->
        <div class="w-full flex justify-center pb-2">
            <a href="/logout" class="text-[9px] text-white/10 hover:text-red-400 transition-colors uppercase tracking-[2px]">
                Sair
            </a>
        </div>
</aside>