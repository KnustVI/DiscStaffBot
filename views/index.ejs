<!DOCTYPE html>
<html>
<head>
    <title>Painel do Bot</title>
    <style>
        body { font-family: sans-serif; background: #2c2f33; color: white; text-align: center; padding: 50px; }
        .btn { background: #5865F2; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-weight: bold; }
        .user-card { margin-top: 20px; background: #23272a; padding: 20px; border-radius: 10px; display: inline-block; }
        img { border-radius: 50%; }
    </style>
</head>
<body>
    <h1>Bem-vindo ao Painel do <%= bot.user.username %></h1>

    <% if (user) { %>
        <div class="user-card">
            <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" width="80">
            <h3>Olá, <%= user.username %>!</h3>
            <p>Você está logado com sucesso.</p>
            <a href="/logout" style="color: #ff5050;">Sair</a>
        </div>
    <% } else { %>
        <p>Faça login para gerenciar o bot.</p>
        <a href="/login" class="btn">Login com Discord</a>
    <% } %>
</body>
</html>