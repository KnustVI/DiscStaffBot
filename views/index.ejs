<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | <%= bot.user.username %></title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg-main: #1F1D20;
            --bg-card: #2A2A2A;
            --bg-inner: #1F1D20;
            --text-primary: #F8DCC0;
            --text-secondary: #A89986;
            --accent: #DCA15E;
            --surface: #803E30;
            --surface-hover: #4B2427;
            --stroke: #5A1811;
            --shadow-black: rgba(0, 0, 0, 0.5);
            --font-head: 'Tilt Warp', cursive;
            --font-body: 'Poppins', sans-serif;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg-main);
            color: var(--text-primary);
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        .login-card {
            background-color: var(--bg-inner);
            width: 100%;
            max-width: 450px;
            padding: 50px 30px;
            border-radius: 40px;
            box-shadow: 20px 20px 60px #131214, -20px -20px 60px #2b282c;
            text-align: center;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .avatar {
            width: 130px;
            height: 130px;
            border-radius: 50%;
            border: 3px solid var(--stroke);
            object-fit: cover;
            margin-bottom: 20px;
            box-shadow: 0 10px 20px var(--shadow-black);
        }

        .nickname {
            font-family: var(--font-head);
            font-size: 2rem;
            color: var(--text-primary);
            text-transform: uppercase;
            margin-bottom: 5px;
            letter-spacing: 1px;
        }

        .role-badge {
            font-family: var(--font-head);
            background-color: var(--surface-hover);
            color: var(--text-primary);
            padding: 6px 20px;
            border-radius: 12px;
            font-size: 0.8rem;
            display: inline-block;
            border: 2px solid var(--stroke);
            margin-bottom: 25px;
        }

        .guilds-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-top: 10px;
        }

        .guild-square {
            aspect-ratio: 1 / 1;
            background-color: var(--bg-card);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(255,255,255,0.03);
            text-decoration: none;
            overflow: hidden;
            padding: 12px; /* Espaçamento interno para diminuir o ícone */
            box-sizing: border-box;
        }

        .guild-square:hover {
            transform: scale(1.08);
            border-color: var(--accent);
            background-color: var(--surface-hover);
        }

        .guild-icon {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 12px; /* Arredondamento suave no ícone interno */
        }

        .guild-initials {
            font-family: var(--font-head);
            color: var(--text-secondary);
            font-size: 1.2rem;
        }

        .btn-primary {
            font-family: var(--font-head);
            background-color: var(--surface);
            color: var(--text-primary);
            padding: 14px 35px;
            border-radius: 14px;
            text-decoration: none;
            display: inline-block;
            transition: 0.3s;
            border: 1px solid var(--stroke);
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            text-transform: uppercase;
            font-size: 1rem;
        }

        .btn-primary:hover {
            background-color: var(--surface-hover);
            box-shadow: 0 0 20px rgba(128, 62, 48, 0.4);
        }

        .footer-text {
            position: absolute;
            bottom: 20px;
            color: var(--text-secondary);
            font-size: 0.65rem;
            letter-spacing: 2px;
            opacity: 0.6;
        }

        .logout {
            margin-top: 25px;
            display: block;
            color: var(--text-secondary);
            font-size: 0.8rem;
            text-decoration: none;
            transition: 0.2s;
        }
        .logout:hover { color: var(--accent); }
    </style>
</head>
<body>

    <div class="login-card">
        <% if (user) { %>
            <img class="avatar" src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" onerror="this.src='https://discord.com/assets/f78426a064bc9dd24847519294b081dd.png'">

            <div class="nickname"><%= user.username %></div>
            
            <div class="role-badge">
                <%= isAdmin ? 'ADMINISTRADOR' : 'STAFF' %>
            </div>

            <% if (isAdmin) { %>
                <div class="guilds-grid">
                    <% guilds.slice(0, 6).forEach(guild => { %>
                        <a href="/home/<%= guild.id %>" class="guild-square">
                            <% if (guild.icon) { %>
                                <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" class="guild-icon">
                            <% } else { %>
                                <span class="guild-initials"><%= guild.name.split(' ').map(i => i[0]).join('') %></span>
                            <% } %>
                        </a>
                    <% }); %>
                </div>
            <% } %>

            <a href="/logout" class="logout">Sair da conta</a>

        <% } else { %>
            <div class="nickname" style="margin-bottom: 20px;">TITAN'S PASS</div>
            <p style="color: var(--text-secondary); font-weight: 300; font-size: 0.9rem; margin-bottom: 30px;">Gerencie seus servidores e punições com precisão.</p>
            <a href="/login" class="btn-primary">Entrar com Discord</a>
        <% } %>
    </div>

    <div class="footer-text">BY: KNUST SEIER VI</div>

</body>
</html>