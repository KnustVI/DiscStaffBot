<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | Titan's Pass</title>
    
    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">
    
    <!-- Chart.js para os Gráficos -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
            <!-- Isso puxa todo o código do arquivo que criamos acima -->
        <%- include('partials/sidebar') %>

        <main class="main-content">
            <!-- Conteúdo específico de cada página aqui -->
        </main>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        
        <!-- FEED + ALERTAS -->
        <div class="feed-alerts">
            <h4>FEED</h4>
        </div>

        <!-- GRÁFICOS 1 -->
        <div class="chart-card">
            <div class="chart-header">Estatísticas de Mensagens</div>
            <div class="canvas-container">
                <canvas id="chartLineArea"></canvas>
            </div>
        </div>

        <!-- GRÁFICOS 2 -->
        <div class="chart-card">
            <div class="chart-header">Novos Membros</div>
            <div class="canvas-container">
                <canvas id="chartRadar"></canvas>
            </div>
        </div>

        <div style="text-align: right; font-size: 0.7rem; color: var(--text-secondary); letter-spacing: 2px;">
            BY: KNUST SEIER VI
        </div>
    </main>

    <script>
        // Configuração do Gráfico 1 (Linha)
        const ctxLine = document.getElementById('chartLineArea').getContext('2d');

            // 1. Criar degradês para a Linha e o Preenchimento
            const gradientLine = ctxLine.createLinearGradient(0, 0, 0, 400);
            gradientLine.addColorStop(0, '#FFC0CB'); // Rosa Claro (Topo)
            gradientLine.addColorStop(1, '#800080'); // Roxo (Base)

            const gradientFill = ctxLine.createLinearGradient(0, 0, 0, 400);
            gradientFill.addColorStop(0, 'rgba(255, 192, 203, 0.4)'); // Rosa Semi-transparente
            gradientFill.addColorStop(1, 'rgba(128, 0, 128, 0.0)');  // Roxo Totalmente Transparente

            new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul'],
                    datasets: [{
                        label: 'Atividade',
                        data: [15, 30, 25, 60, 45, 80, 70], // Dados de exemplo
                        borderColor: gradientLine, // Aplica o degradê na linha
                        backgroundColor: gradientFill, // Aplica o degradê no preenchimento
                        fill: true, // Preenche a área sob a linha
                        tension: 0.4, // Suaviza as curvas (crucial para o visual)
                        borderWidth: 3,
                        pointRadius: 0, // Remove os pontos para um visual mais limpo
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } }, // Esconde a legenda
                    scales: {
                        // Estilização dos eixos para combinar com o tema escuro
                        y: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }, // Linhas de grade sutis
                            ticks: { color: '#A89986' } // Cor do texto dos ticks
                        },
                        x: {
                            grid: { display: false }, // Esconde a grade vertical
                            ticks: { color: '#A89986' }
                        }
                    }
                }
            });

        // Configuração do Gráfico 2 (Barras)
            const ctxRadar = document.getElementById('chartRadar').getContext('2d');

            new Chart(ctxRadar, {
                type: 'radar',
                data: {
                    labels: ['Força', 'Agilidade', 'Inteligência', 'Magia', 'Defesa', 'Sorte'],
                    datasets: [{
                        label: 'Estatísticas Atuais',
                        data: [85, 70, 90, 60, 75, 50], // Dados de exemplo
                        borderColor: '#00FFFF', // Ciano Neon
                        backgroundColor: 'rgba(0, 255, 255, 0.15)', // Ciano Semi-transparente
                        borderWidth: 2,
                        pointBackgroundColor: '#FFFFFF',
                        pointBorderColor: '#00FFFF',
                        pointRadius: 4,
                    },
                    {
                        label: 'Média do Servidor',
                        data: [65, 75, 60, 80, 60, 70],
                        borderColor: '#FF00FF', // Magenta Neon
                        backgroundColor: 'rgba(255, 0, 255, 0.1)', // Magenta Semi-transparente
                        borderWidth: 1,
                        pointRadius: 0,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        r: {
                            // Estilização específica para o gráfico de radar
                            angleLines: { color: 'rgba(255, 255, 255, 0.1)' }, // Linhas diagonais
                            grid: { color: 'rgba(255, 255, 255, 0.1)' }, // Círculos concêntricos
                            pointLabels: { color: '#A89986', font: { size: 12 } }, // Rótulos dos cantos
                            ticks: { display: false } // Esconde os números do eixo central
                        }
                    }
                }
            });
    </script>
</body>
</html>