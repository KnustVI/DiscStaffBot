<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | <%= bot.user.username %></title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&family=Bebas+Neue&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="css/style.css">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'titan-bg': '#0D0D0D',
                        'titan-accent': '#803E30',
                        'titan-cream': '#F8DCC0',
                        'titan-gold': '#D9A362',
                    }
                }
            }
        }
    </script>

</head>
<body class="flex min-h-screen">

    <!-- SIDEBAR (Ajustada com padding de 30px no arquivo partial) -->
    <aside class="w-[300px] hidden lg:block h-screen sticky top-0">
        <%- include('partials/sidebar') %>
    </aside>

    <!-- CONTEÚDO PRINCIPAL (Margem de 30px em tudo) -->
    <main class="flex-1 flex flex-col p-[30px] gap-[30px] overflow-y-auto">
        
        <!-- HEADER -->
        <header class="flex justify-between items-end px-2">
            <div>
                <h1 class="tilt-warp text-2xl uppercase tracking-[1px]">Dashboard de <%= guild.name %></h1>
                <p class="text-[11px] opacity-40 uppercase tracking-[2px]">Bem-vindo de volta, <span class="text-titan-gold"><%= nickname %></span></p>
            </div>
            <div class="text-right">
                <p class="text-[10px] uppercase tracking-widest opacity-30">Cargo Atual</p>
                <p class="bebas text-xl text-titan-accent tracking-[1.5px] uppercase"><%= role %></p>
            </div>
        </header>           

                <!-- Seção de Estatísticas -->
        <section class="titan-card-premium justify-evenly items-center flex">
            
            <!-- Gráfico 1: Retenção -->
            <div class="relative flex-1 items-center">
                <div class="premium-card-graph-container">
                    <svg class="premium-graph-inner" viewBox="0 0 100 100">
                    <circle class="premium-circle-34" cx="50" cy="50" r="35"></circle>
                    <circle class="premium-circle-shadow" cx="50" cy="50" r="35"></circle>
                            <circle class="premium-circle-bg" cx="50" cy="50" r="35"></circle>
                            
                            <circle class="premium-circle-progress" 
                                    cx="50" cy="50" r="35" 
                                    stroke-dasharray="270.2" 
                                    stroke-dashoffset="135.1">
                            </circle>
                        </svg>
                        <div class="premium-graph-label-container">
                            <span class="premium-graph-title">Retenção</span>
                            <span class="premium-graph-value">50/100</span>
                        </div>
                </div>
            </div>

            <!-- Gráfico 2: Staffs -->
            <div class="relative flex-1 items-center">
                <div class="premium-card-graph-container">
                    <svg class="premium-graph-inner" viewBox="0 0 100 100">
                    <circle class="premium-circle-34" cx="50" cy="50" r="35"></circle>
                    <circle class="premium-circle-shadow" cx="50" cy="50" r="35"></circle>
                            <circle class="premium-circle-bg" cx="50" cy="50" r="35"></circle>
                            
                            <circle class="premium-circle-progress" 
                                    cx="50" cy="50" r="35" 
                                    stroke-dasharray="270.2" 
                                    stroke-dashoffset="135.1">
                            </circle>
                        </svg>
                        <div class="premium-graph-label-container">
                            <span class="premium-graph-title">Staffs Ativos</span>
                            <span class="premium-graph-value">50/100</span>
                        </div>
                </div>
            </div>

            <!-- Gráfico 3: Strikes -->
            <div class="relative flex-1 items-center">
                <div class="premium-card-graph-container">
                    <svg class="premium-graph-inner" viewBox="0 0 100 100">
                    <circle class="premium-circle-34" cx="50" cy="50" r="35"></circle>
                    <circle class="premium-circle-shadow" cx="50" cy="50" r="35"></circle>
                            <circle class="premium-circle-bg" cx="50" cy="50" r="35"></circle>
                            
                            <circle class="premium-circle-progress" 
                                    cx="50" cy="50" r="35" 
                                    stroke-dasharray="270.2" 
                                    stroke-dashoffset="135.1">
                            </circle>
                        </svg>
                        <div class="premium-graph-label-container">
                            <span class="premium-graph-title">Strikes</span>
                            <span class="premium-graph-value">50/100</span>
                        </div>
                </div>
            </div>

          <!-- Gráfico 4: Usuários ATIVOS -->
            <div class="relative flex-1 flex items-center">
                <div class="premium-card-graph-container">
                    <svg class="premium-graph-inner" viewBox="0 0 100 100">
                    <circle class="premium-circle-34" cx="50" cy="50" r="35"></circle>
                    <circle class="premium-circle-shadow" cx="50" cy="50" r="35"></circle>
                            <circle class="premium-circle-bg" cx="50" cy="50" r="35"></circle>
                            
                            <circle class="premium-circle-progress" 
                                    cx="50" cy="50" r="35" 
                                    stroke-dasharray="270.2" 
                                    stroke-dashoffset="135.1">
                            </circle>
                        </svg>
                        <div class="premium-graph-label-container">
                            <span class="premium-graph-title">Usuários Ativos</span>
                            <span class="premium-graph-value">50/100</span>
                        </div>
                </div>
            </div>

        </section>

        <section class="titan-card-premium justify-evenly items-center flex"> </section>

        <!-- FOOTER / BY -->
        <footer class="flex justify-end pb-2">
            <span class="bebas text-[12px] uppercase tracking-[6px] text-titan-cream opacity-10 hover:opacity-30 transition-opacity">
                BY: KNUST SEIER VI
            </span>
        </footer>
    </main>

        <script>
        function updateChart(id, percent) {
            const circle = document.getElementById(id);
            const radius = circle.r.baseVal.value;
            const circumference = 2 * Math.PI * radius;
            
            circle.style.strokeDasharray = `${circumference} ${circumference}`;
            // O cálculo do offset (ex: 50% preenchido)
            const offset = circumference - (percent / 100) * circumference;
            circle.style.strokeDashoffset = offset;
        }

        window.addEventListener('load', () => {
            // Exemplo: todos em 50% como no seu print
            updateChart('circle-retencao', 50);
            updateChart('circle-staffs', 50);
            updateChart('circle-strikes', 50);
            updateChart('circle-online', 75); // Esse parece maior no print
        });
    </script>
    </body>
</html>