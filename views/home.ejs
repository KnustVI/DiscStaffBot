<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | Titan's Pass</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'titan-bg': '#131314',
                        'titan-card': '#1F1D20',
                        'titan-accent': '#803E30',
                        'titan-cream': '#F8DCC0',
                        'titan-gold': '#D9A362',
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #131314;
            color: #F8DCC0;
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden;
        }

        /* Efeito de Profundidade dos Cards (Neomorfismo Dark) */
        .premium-card {
            background: #1F1D20;
            border: 1px solid rgba(248, 220, 192, 0.05);
            border-radius: 24px;
            box-shadow: 10px 10px 20px #0a0a0b, -5px -5px 15px rgba(255,255,255,0.02);
        }

        /* Gráfico Circular Customizado via CSS */
        .progress-ring {
            position: relative;
            width: 140px;
            height: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .progress-ring svg {
            transform: rotate(-90deg);
        }

        .progress-ring circle {
            fill: none;
            stroke-width: 12;
            stroke-linecap: round;
        }

        .circle-bg { stroke: #2a282b; }
        .circle-main { stroke: #D9A362; transition: stroke-dashoffset 1s ease-in-out; }
        .circle-alt { stroke: #803E30; }

        .chart-label {
            position: absolute;
            text-align: center;
            font-size: 0.7rem;
            line-height: 1.2;
            color: rgba(248, 220, 192, 0.8);
        }
    </style>
</head>
<body class="flex min-h-screen p-4 gap-6">

    <!-- SIDEBAR (Injetada) -->
    <aside class="w-72 hidden lg:block">
        <%- include('partials/sidebar') %>
    </aside>

    <!-- CONTEÚDO PRINCIPAL -->
    <main class="flex-1 flex flex-col gap-6">
        
        <!-- SEÇÃO DE GRÁFICOS SUPERIORES (KPIs) -->
        <section class="premium-card p-8 flex flex-wrap justify-around items-center gap-8">
            
            <!-- Retenção -->
            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle class="circle-main" cx="70" cy="70" r="60" style="stroke-dasharray: 377; stroke-dashoffset: 188;"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="block font-semibold">Retenção de<br>usuários</span>
                        <span class="text-xs opacity-60">50/100</span>
                    </div>
                </div>
            </div>

            <!-- Staffs Ativos -->
            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle class="circle-main" cx="70" cy="70" r="60" style="stroke-dasharray: 377; stroke-dashoffset: 150;"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="block font-semibold">Staffs Ativos</span>
                        <span class="text-xs opacity-60">60/100</span>
                    </div>
                </div>
            </div>

            <!-- Strikes -->
            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle class="circle-main" cx="70" cy="70" r="60" style="stroke-dasharray: 377; stroke-dashoffset: 280;"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="block font-semibold">Strikes</span>
                        <span class="text-xs opacity-60">25/100</span>
                    </div>
                </div>
            </div>

            <!-- Players Online -->
            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle class="circle-alt" cx="70" cy="70" r="60" style="stroke-dasharray: 377; stroke-dashoffset: 100;"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="block font-semibold">Players Online</span>
                        <span class="text-xs opacity-60">75/100</span>
                    </div>
                </div>
            </div>

        </section>

        <!-- SEÇÃO INFERIOR (CONTEÚDO DINÂMICO) -->
        <section class="premium-card flex-1 p-8">
            <h2 class="tilt-warp text-xl uppercase tracking-widest opacity-20">Área de Dados Gerais</h2>
            <!-- Espaço para seus gráficos de linha ou tabelas -->
        </section>

        <!-- FOOTER ASSINATURA -->
        <div class="text-right">
            <span class="text-[10px] uppercase tracking-[5px] text-titan-cream opacity-20 tilt-warp">
                BY: KNUST SEIER VI
            </span>
        </div>
    </main>

</body>
</html>