<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | <%= bot.user.username %></title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'titan-bg': '#131314',
                        'titan-accent': '#803E30',
                        'titan-cream': '#F8DCC0',
                        'titan-gold': '#D9A362',
                    }
                }
            }
        }
    </script>

    <style>
        body {
            background-color: #131314;
            color: #F8DCC0;
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden;
        }

        /* Aplicando seu Estilo Exato como Classe */
        .titan-container-style {
        border-radius: 20px;
        box-shadow: -25px 47px 68.1px #000000bd, 0.5px -0.5px 0.5px #f8dcc0;
        background: linear-gradient(180deg, #252326 0%, #1F1D20 54.34%, #131314 98.29%);
        border: 1px solid rgba(248, 220, 192, 0.03);
        }
        

        .progress-ring {
            position: relative;
            width: 140px;
            height: 140px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .progress-ring svg { transform: rotate(-90deg); }
        .progress-ring circle { fill: none; stroke-width: 12; stroke-linecap: round; }
        .circle-bg { stroke: #2a282b; }
        .circle-main { stroke: #D9A362; transition: stroke-dashoffset 1s ease-in-out; }
        .circle-alt { stroke: #803E30; transition: stroke-dashoffset 1s ease-in-out; }

        .chart-label {
            position: absolute;
            text-align: center;
            font-size: 0.7rem;
            line-height: 1.2;
            color: rgba(248, 220, 192, 0.8);
        }
    </style>
</head>
<body class="flex min-h-screen p-4 gap-6">

    <aside class="w-72 hidden lg:block h-[calc(100vh-2rem)] sticky top-4">
        <%- include('partials/sidebar') %>
    </aside>

    <main class="flex-1 flex flex-col gap-6 overflow-y-auto">
        
        <header class="flex justify-between items-center px-4">
            <div>
                <h1 class="tilt-warp text-2xl uppercase tracking-tighter">Dashboard de <%= guild.name %></h1>
                <p class="text-xs opacity-50">Bem-vindo de volta, <span class="text-titan-gold"><%= nickname %></span></p>
            </div>
            <div class="text-right">
                <p class="text-[10px] uppercase tracking-widest opacity-40">Cargo Atual</p>
                <p class="text-sm font-bold text-titan-accent uppercase"><%= role %></p>
            </div>
        </header>

        <!-- SEÇÃO DE GRÁFICOS COM SEU ESTILO -->
        <section class="titan-container-style p-8 flex flex-wrap justify-around items-center gap-8">
            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle id="circle-rep" class="circle-main" cx="70" cy="70" r="60" style="stroke-dasharray: 377; stroke-dashoffset: 377;"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="block font-semibold uppercase tracking-tighter text-[10px]">Sua Reputação</span>
                        <span class="text-xs text-titan-gold"><%= reputation %>/100</span>
                    </div>
                </div>
            </div>

            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle id="circle-lvl" class="circle-main" cx="70" cy="70" r="60" style="stroke-dasharray: 377; stroke-dashoffset: 377;"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="block font-semibold uppercase tracking-tighter text-[10px]">Nível Atividade</span>
                        <span class="text-xs text-titan-gold">Lvl <%= level %></span>
                    </div>
                </div>
            </div>

            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle id="circle-online" class="circle-alt" cx="70" cy="70" r="60" style="stroke-dasharray: 377; stroke-dashoffset: 377;"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="block font-semibold uppercase tracking-tighter text-[10px]">Membros Servidor</span>
                        <span class="text-xs text-titan-accent"><%= guild.memberCount %></span>
                    </div>
                </div>
            </div>
        </section>

        <!-- SEÇÃO INFERIOR COM SEU ESTILO -->
        <section class="titan-container-style flex-1 p-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="tilt-warp text-xl uppercase tracking-widest opacity-30">Informações do Servidor</h2>
                <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" 
                     onerror="this.src='https://discord.com/assets/f78426a064bc9dd24847519294b081dd.png'"
                     class="w-12 h-12 rounded-2xl border border-[#f8dcc0]/20 shadow-xl">
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="bg-black/20 p-4 rounded-xl border border-white/5">
                    <p class="text-[10px] uppercase opacity-40">ID do Servidor</p>
                    <p class="text-sm font-mono tracking-tighter"><%= guild.id %></p>
                </div>
                <div class="bg-black/20 p-4 rounded-xl border border-white/5">
                    <p class="text-[10px] uppercase opacity-40">Total de Membros</p>
                    <p class="text-sm tracking-tight"><%= guild.memberCount %> usuários</p>
                </div>
            </div>
        </section>

        <div class="text-right pb-4">
            <span class="text-[10px] uppercase tracking-[5px] text-titan-cream opacity-20 tilt-warp">BY: KNUST SEIER VI</span>
        </div>
    </main>

    <script>
        function setProgress(elementId, value, max) {
            const circle = document.getElementById(elementId);
            if (!circle) return;
            const val = parseFloat(value) || 0;
            const maximum = parseFloat(max) || 100;
            const radius = circle.r.baseVal.value;
            const circumference = 2 * Math.PI * radius;
            const offset = circumference - (val / maximum) * circumference;
            circle.style.strokeDasharray = `${circumference}`;
            circle.style.strokeDashoffset = offset;
        }
        window.onload = () => {
            setProgress('circle-rep', Number("<%= reputation %>"), 100);
            setProgress('circle-lvl', Number("<%= level %>"), 10);
            setProgress('circle-online', 100, 100);
        };
    </script>
</body>
</html>