<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | Titan's Pass</title>
    
    <!-- Fontes -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">
    
    <!-- Chart.js para os Gráficos -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --bg-main: #1F1D20;
            --bg-sidebar: #252326;
            --bg-card: #2A2A2A;
            --text-primary: #F8DCC0;
            --text-secondary: #A89986;
            --accent: #DCA15E;
            --surface: #803E30;
            --surface-hover: #4B2427;
            --stroke: #5A1811;
            --font-head: 'Tilt Warp', cursive;
            --font-body: 'Poppins', sans-serif;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg-main);
            color: var(--text-primary);
            margin: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* SIDEBAR (ESQUERDA) */
        .sidebar {
            width: 320px;
            background-color: var(--bg-sidebar);
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
            border-right: 1px solid var(--stroke);
            box-shadow: 10px 0 30px rgba(0,0,0,0.3);
            z-index: 10;
        }

        .logo-titans {
            width: 180px;
            margin-bottom: 30px;
            filter: drop-shadow(0 5px 15px rgba(0,0,0,0.5));
        }

        .nav-menu {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: auto;
        }

        .nav-item {
            font-family: var(--font-head);
            text-decoration: none;
            color: var(--text-secondary);
            background: rgba(255,255,255,0.03);
            padding: 12px;
            border-radius: 12px;
            text-align: center;
            border: 1px solid var(--stroke);
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-size: 0.9rem;
        }

        .nav-item:hover {
            background: var(--surface-hover);
            color: var(--text-primary);
            transform: translateX(5px);
        }

        /* PERFIL STAFF (DENTRO DA SIDEBAR) */
        .staff-profile {
            width: 100%;
            padding-top: 20px;
            border-top: 1px solid var(--stroke);
            display: grid;
            grid-template-columns: 80px 1fr;
            gap: 15px;
            align-items: center;
        }

        .staff-avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            border: 2px solid var(--accent);
            object-fit: cover;
        }

        .staff-info .name {
            font-family: var(--font-head);
            font-size: 1.1rem;
            text-transform: uppercase;
        }

        .staff-info .role {
            background: var(--surface);
            font-size: 0.65rem;
            padding: 2px 8px;
            border-radius: 5px;
            display: inline-block;
        }

        .staff-stats {
            margin-top: 10px;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }

        .stat-tag {
            background: var(--accent);
            color: var(--bg-main);
            font-size: 0.7rem;
            font-weight: bold;
            padding: 2px 10px;
            border-radius: 4px;
            text-align: center;
        }

        /* ÁREA PRINCIPAL (DIREITA) */
        .main-content {
            flex: 1;
            padding: 40px;
            display: flex;
            flex-direction: column;
            gap: 30px;
            overflow-y: auto;
            position: relative;
        }

        /* QUADRO DE ALERTAS (VERMELHO - ESTILO TAG SUSPENSA) */
        .feed-alerts {
            position: absolute;
            top: 0;
            right: 50px;
            width: 180px;
            background: #4B2427; /* Color Surface 2 */
            padding: 25px 15px;
            border-radius: 0 0 20px 20px;
            border: 2px solid var(--stroke);
            border-top: none;
            text-align: center;
            box-shadow: 0 10px 20px rgba(0,0,0,0.4);
            z-index: 5;
        }

        .feed-alerts h4 {
            font-family: var(--font-head);
            margin: 0;
            color: var(--text-primary);
            letter-spacing: 2px;
        }

        /* CARDS DE GRÁFICOS */
        .chart-card {
            background: var(--bg-card);
            border-radius: 25px;
            padding: 30px;
            min-height: 250px;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 20px 20px 60px #131214;
            display: flex;
            flex-direction: column;
        }

        .chart-header {
            font-family: var(--font-head);
            font-size: 1.5rem;
            margin-bottom: 20px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 2px;
            text-align: center;
        }

        .canvas-container {
            flex: 1;
            position: relative;
        }
    </style>
</head>
<body>

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <!-- COLOQUE O LINK DA SUA LOGO ABAIXO -->
        <img src="https://i.ibb.co/whjd7DYJ/Titans-pass-logo.png" alt="Titan's Pass" class="logo-titans">

        <nav class="nav-menu">
            <a href="/manage/<%= guild.id %>" class="nav-item">Configurações</a>
            <a href="#" class="nav-item">Tickets</a>
            <a href="#" class="nav-item">Staffs</a>
            <a href="#" class="nav-item">Strikes</a>
        </nav>

        <div class="staff-profile">
    <!-- Avatar do Usuário -->
    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" 
         onerror="this.src='https://discord.com/assets/f78426a064bc9dd24847519294b081dd.png'" 
         class="staff-avatar">
         
    <div class="staff-info">
        <!-- Nickname (Nome no servidor) -->
        <div class="name"><%= nickname %></div>
        
        <!-- Maior cargo no Discord -->
        <div class="role"><%= role %></div>
        
        <div class="staff-stats">
            <!-- Nível vindo do DB -->
            <div class="stat-tag">NV. <%= level %></div>
            
            <!-- Reputação vinda do DB -->
            <div class="stat-tag" style="background: var(--text-primary); color: var(--bg-main);">
                REP: <%= reputation %>
            </div>
        </div>
    </div>
</div>

    <!-- MAIN CONTENT -->
    <main class="main-content">
        
        <!-- FEED + ALERTAS -->
        <div class="feed-alerts">
            <h4>FEED</h4>
        </div>

        <!-- GRÁFICOS 1 -->
        <div class="chart-card">
            <div class="chart-header">Estatísticas de Mensagens</div>
            <div class="canvas-container">
                <canvas id="chartLineArea"></canvas>
            </div>
        </div>

        <!-- GRÁFICOS 2 -->
        <div class="chart-card">
            <div class="chart-header">Novos Membros</div>
            <div class="canvas-container">
                <canvas id="chartRadar"></canvas>
            </div>
        </div>

        <div style="text-align: right; font-size: 0.7rem; color: var(--text-secondary); letter-spacing: 2px;">
            BY: KNUST SEIER VI
        </div>
    </main>

    <script>
        // Configuração do Gráfico 1 (Linha)
        const ctxLine = document.getElementById('chartLineArea').getContext('2d');

            // 1. Criar degradês para a Linha e o Preenchimento
            const gradientLine = ctxLine.createLinearGradient(0, 0, 0, 400);
            gradientLine.addColorStop(0, '#FFC0CB'); // Rosa Claro (Topo)
            gradientLine.addColorStop(1, '#800080'); // Roxo (Base)

            const gradientFill = ctxLine.createLinearGradient(0, 0, 0, 400);
            gradientFill.addColorStop(0, 'rgba(255, 192, 203, 0.4)'); // Rosa Semi-transparente
            gradientFill.addColorStop(1, 'rgba(128, 0, 128, 0.0)');  // Roxo Totalmente Transparente

            new Chart(ctxLine, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul'],
                    datasets: [{
                        label: 'Atividade',
                        data: [15, 30, 25, 60, 45, 80, 70], // Dados de exemplo
                        borderColor: gradientLine, // Aplica o degradê na linha
                        backgroundColor: gradientFill, // Aplica o degradê no preenchimento
                        fill: true, // Preenche a área sob a linha
                        tension: 0.4, // Suaviza as curvas (crucial para o visual)
                        borderWidth: 3,
                        pointRadius: 0, // Remove os pontos para um visual mais limpo
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } }, // Esconde a legenda
                    scales: {
                        // Estilização dos eixos para combinar com o tema escuro
                        y: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)' }, // Linhas de grade sutis
                            ticks: { color: '#A89986' } // Cor do texto dos ticks
                        },
                        x: {
                            grid: { display: false }, // Esconde a grade vertical
                            ticks: { color: '#A89986' }
                        }
                    }
                }
            });

        // Configuração do Gráfico 2 (Barras)
            const ctxRadar = document.getElementById('chartRadar').getContext('2d');

            new Chart(ctxRadar, {
                type: 'radar',
                data: {
                    labels: ['Força', 'Agilidade', 'Inteligência', 'Magia', 'Defesa', 'Sorte'],
                    datasets: [{
                        label: 'Estatísticas Atuais',
                        data: [85, 70, 90, 60, 75, 50], // Dados de exemplo
                        borderColor: '#00FFFF', // Ciano Neon
                        backgroundColor: 'rgba(0, 255, 255, 0.15)', // Ciano Semi-transparente
                        borderWidth: 2,
                        pointBackgroundColor: '#FFFFFF',
                        pointBorderColor: '#00FFFF',
                        pointRadius: 4,
                    },
                    {
                        label: 'Média do Servidor',
                        data: [65, 75, 60, 80, 60, 70],
                        borderColor: '#FF00FF', // Magenta Neon
                        backgroundColor: 'rgba(255, 0, 255, 0.1)', // Magenta Semi-transparente
                        borderWidth: 1,
                        pointRadius: 0,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        r: {
                            // Estilização específica para o gráfico de radar
                            angleLines: { color: 'rgba(255, 255, 255, 0.1)' }, // Linhas diagonais
                            grid: { color: 'rgba(255, 255, 255, 0.1)' }, // Círculos concêntricos
                            pointLabels: { color: '#A89986', font: { size: 12 } }, // Rótulos dos cantos
                            ticks: { display: false } // Esconde os números do eixo central
                        }
                    }
                }
            });
    </script>
</body>
</html>