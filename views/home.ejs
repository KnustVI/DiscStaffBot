<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home | <%= bot.user.username %></title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&family=Bebas+Neue&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'titan-bg': '#0D0D0D',
                        'titan-accent': '#803E30',
                        'titan-cream': '#F8DCC0',
                        'titan-gold': '#D9A362',
                    }
                }
            }
        }
    </script>

</head>
<body class="flex min-h-screen">

    <!-- SIDEBAR (Ajustada com padding de 30px no arquivo partial) -->
    <aside class="w-[300px] hidden lg:block h-screen sticky top-0">
        <%- include('partials/sidebar') %>
    </aside>

    <!-- CONTEÚDO PRINCIPAL (Margem de 30px em tudo) -->
    <main class="flex-1 flex flex-col p-[30px] gap-[30px] overflow-y-auto">
        
        <!-- HEADER -->
        <header class="flex justify-between items-end px-2">
            <div>
                <h1 class="tilt-warp text-2xl uppercase tracking-[1px]">Dashboard de <%= guild.name %></h1>
                <p class="text-[11px] opacity-40 uppercase tracking-[2px]">Bem-vindo de volta, <span class="text-titan-gold"><%= nickname %></span></p>
            </div>
            <div class="text-right">
                <p class="text-[10px] uppercase tracking-widest opacity-30">Cargo Atual</p>
                <p class="bebas text-xl text-titan-accent tracking-[1.5px] uppercase"><%= role %></p>
            </div>
        </header>

        <!-- SEÇÃO DE ESTATÍSTICAS (O Card Superior) -->
        <section class="titan-card-premium p-[40px] flex flex-wrap justify-around items-center gap-10">
            
            <!-- Reputação -->
            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140" class="rotate-[-90deg]">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle id="circle-rep" class="circle-main" cx="70" cy="70" r="60"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="tilt-warp text-[9px] uppercase opacity-60 leading-tight">Sua<br>Reputação</span>
                        <span class="bebas text-lg text-titan-gold mt-1"><%= reputation %>/100</span>
                    </div>
                </div>
            </div>

            <!-- Nível -->
            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140" class="rotate-[-90deg]">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle id="circle-lvl" class="circle-main" cx="70" cy="70" r="60"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="tilt-warp text-[9px] uppercase opacity-60 leading-tight">Nível<br>Atividade</span>
                        <span class="bebas text-lg text-titan-gold mt-1">LVL <%= level %></span>
                    </div>
                </div>
            </div>

            <!-- Membros -->
            <div class="flex flex-col items-center">
                <div class="progress-ring">
                    <svg width="140" height="140" class="rotate-[-90deg]">
                        <circle class="circle-bg" cx="70" cy="70" r="60"></circle>
                        <circle id="circle-online" class="circle-alt" cx="70" cy="70" r="60"></circle>
                    </svg>
                    <div class="chart-label">
                        <span class="tilt-warp text-[9px] uppercase opacity-60 leading-tight">Membros<br>Servidor</span>
                        <span class="bebas text-lg text-titan-accent mt-1"><%= guild.memberCount %></span>
                    </div>
                </div>
            </div>
        </section>

                <!-- Seção de Estatísticas -->
        <section class="titan-card-premium p-[40px] flex justify-between items-center gap-4">
            
            <!-- Gráfico 1: Retenção -->
            <div class="relative flex-1 flex flex-col items-center">
                <div class="progress-ring relative w-[160px] h-[160px]">
                    <svg width="160" height="160">
                        <circle class="circle-bg" cx="80" cy="80" r="70"></circle>
                        <circle id="circle-retencao" class="circle-main color-gold" cx="80" cy="80" r="70"></circle>
                    </svg>
                    <div class="chart-label-container">
                        <span class="text-[10px] uppercase opacity-60 leading-tight">Retenção de<br>usuários</span>
                        <span class="text-xs mt-1">50/100</span>
                    </div>
                </div>
            </div>

            <!-- Gráfico 2: Staffs -->
            <div class="relative flex-1 flex flex-col items-center">
                <div class="progress-ring relative w-[160px] h-[160px]">
                    <svg width="160" height="160">
                        <circle class="circle-bg" cx="80" cy="80" r="70"></circle>
                        <circle id="circle-staffs" class="circle-main color-gold" cx="80" cy="80" r="70"></circle>
                    </svg>
                    <div class="chart-label-container">
                        <span class="text-[10px] uppercase opacity-60 leading-tight">Staffs Ativos</span>
                        <span class="text-xs mt-1">50/100</span>
                    </div>
                </div>
            </div>

            <!-- Gráfico 3: Strikes -->
            <div class="relative flex-1 flex flex-col items-center">
                <div class="progress-ring relative w-[160px] h-[160px]">
                    <svg width="160" height="160">
                        <circle class="circle-bg" cx="80" cy="80" r="70"></circle>
                        <circle id="circle-strikes" class="circle-main color-gold" cx="80" cy="80" r="70"></circle>
                    </svg>
                    <div class="chart-label-container">
                        <span class="text-[10px] uppercase opacity-60 leading-tight">Strikes</span>
                        <span class="text-xs mt-1">50/100</span>
                    </div>
                </div>
            </div>

            <!-- Gráfico 4: Players Online (Cor Diferente) -->
            <div class="relative flex-1 flex flex-col items-center">
                <div class="progress-ring relative w-[160px] h-[160px]">
                    <svg width="160" height="160">
                        <circle class="circle-bg" cx="80" cy="80" r="70"></circle>
                        <circle id="circle-online" class="circle-main color-dark-red" cx="80" cy="80" r="70"></circle>
                    </svg>
                    <div class="chart-label-container">
                        <span class="text-[10px] uppercase opacity-60 leading-tight">Players Online</span>
                        <span class="text-xs mt-1">50/100</span>
                    </div>
                </div>
            </div>

        </section>

        <!-- FOOTER / BY -->
        <footer class="flex justify-end pb-2">
            <span class="bebas text-[12px] uppercase tracking-[6px] text-titan-cream opacity-10 hover:opacity-30 transition-opacity">
                BY: KNUST SEIER VI
            </span>
        </footer>
    </main>

        <script>
        function updateChart(id, percent) {
            const circle = document.getElementById(id);
            const radius = circle.r.baseVal.value;
            const circumference = 2 * Math.PI * radius;
            
            circle.style.strokeDasharray = `${circumference} ${circumference}`;
            // O cálculo do offset (ex: 50% preenchido)
            const offset = circumference - (percent / 100) * circumference;
            circle.style.strokeDashoffset = offset;
        }

        window.addEventListener('load', () => {
            // Exemplo: todos em 50% como no seu print
            updateChart('circle-retencao', 50);
            updateChart('circle-staffs', 50);
            updateChart('circle-strikes', 50);
            updateChart('circle-online', 75); // Esse parece maior no print
        });
    </script>
    </body>
</html>