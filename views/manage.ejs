<!DOCTYPE html>
<html lang="pt-br">
<head>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
    <!-- <script src="https://cdn.jsdelivr.net/npm/chart.js"></script> -->
     
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações | Titan's Pass</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Font Awesome para os ícones nos inputs -->
</head>
<body>
    <!-- Inclui a Sidebar Padronizada (já com o botão Home) -->
    <%- include('partials/sidebar') %>

    <main class="content">
        <div class="header-meta">BY: KNUST SEIER VI</div>

        <form action="/manage/<%= guild.id %>/save" method="POST">
            
            <div class="config-row">
                <!-- COLUNA 1: CONFIGS GERAIS -->
                <div class="config-card">
                    <h3 class="section-title">Configurações</h3>
                    
                    <div class="input-group">
                        <div class="input-icon"><i class="fa-solid fa-user-shield"></i></div>
                        <input type="text" class="input-field" placeholder="Cargo Staff" name="staffRole">
                    </div>

                    <div class="input-group">
                        <div class="input-icon"><i class="fa-solid fa-terminal"></i></div>
                        <input type="text" class="input-field" placeholder="Canal de Logs" name="logChannel">
                    </div>
                </div>

                <!-- COLUNA 2: REPUTAÇÃO -->
                <div class="config-card">
                    <h3 class="section-title">Reputação por Dia</h3>
                    <div class="input-group">
                        <div class="input-icon"><i class="fa-solid fa-circle-user"></i></div>
                        <input type="number" class="input-field" placeholder="Número" name="dailyRep">
                    </div>
                </div>
            </div>

            <!-- REGRAS DE PUNIÇÃO (CARD LARGO) -->
            <div class="config-card" style="margin-top: 25px;">
                <h3 class="section-title">Regras de Punição</h3>
                
                <div class="punishment-grid">
                    <% [1, 2, 3, 4, 5].forEach(level => { %>
                    <div class="punishment-item">
                        <span class="level-label">Nível <%= level %></span>
                        <div class="input-group" style="margin-bottom: 0;">
                            <input type="text" class="input-field" placeholder="-<%= level * 20 %> pts" name="punish_level_<%= level %>">
                        </div>
                    </div>
                    <% }) %>
                </div>

                <div class="save-container">
                    <button type="submit" class="btn-save">Salvar</button>
                </div>
            </div>

        </form>
    </main>

</body>
</html>