<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações | Titan's Pass</title>
    
    <!-- Google Fonts: Poppins e Tilt Warp -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&family=Tilt+Warp&display=swap" rel="stylesheet">

    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        :root {
            --bg-color: #1A181B;
            --card-bg: #232124;
            --accent-color: #F8DCC0; /* Bege Ouro */
            --input-bg: rgba(0, 0, 0, 0.25);
            --font-main: 'Poppins', sans-serif;
            --font-title: 'Tilt Warp', cursive;
        }

        body {
            background-color: var(--bg-color);
            color: var(--accent-color);
            font-family: var(--font-main);
            margin: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* Tipografia */
        .section-title {
            font-family: var(--font-title);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 1.1rem;
            color: var(--accent-color);
            margin-bottom: 25px;
        }

        .label-text {
            font-family: var(--font-main);
            font-weight: 600;
            font-size: 0.75rem;
            letter-spacing: 1px;
            opacity: 0.7;
        }

        /* Cards */
        .titan-card-premium {
            background: var(--card-bg);
            border: 1px solid rgba(248, 220, 192, 0.08);
            border-radius: 15px;
            padding: 35px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
            width: 100%;
        }

        /* Containers de Input */
        .input-container-premium {
            display: flex;
            align-items: center;
            background: var(--input-bg);
            border: 1px solid rgba(248, 220, 192, 0.15);
            border-radius: 8px;
            margin-bottom: 18px;
            overflow: hidden;
            height: 48px;
            transition: border 0.3s;
        }

        .input-container-premium:focus-within {
            border-color: var(--accent-color);
        }

        .icon-box {
            background: var(--accent-color);
            color: #1A181B;
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 1.2rem;
        }

        .input-premium-field {
            background: transparent;
            border: none;
            color: var(--accent-color);
            padding: 0 15px;
            width: 100%;
            height: 100%;
            outline: none;
            font-family: var(--font-main);
            font-size: 0.9rem;
        }

        /* Botão */
        .btn-salvar-final {
            font-family: var(--font-title);
            background: transparent;
            border: 2px solid var(--accent-color);
            color: var(--accent-color);
            padding: 14px 50px;
            border-radius: 10px;
            text-transform: uppercase;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-salvar-final:hover {
            background: var(--accent-color);
            color: #1A181B;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(248, 220, 192, 0.2);
        }

        main::-webkit-scrollbar { width: 6px; }
        main::-webkit-scrollbar-thumb { background: rgba(248, 220, 192, 0.1); border-radius: 10px; }
    </style>
</head>

<body>

    <aside class="w-[300px] hidden lg:block h-screen sticky top-0">
        <%- include('partials/sidebar') %>
    </aside>

    <main class="flex-1 w-full flex flex-col p-[30px] gap-[30px] overflow-y-auto">

        <form action="/manage/<%= guild.id %>/save" method="POST" class="flex flex-col gap-8">
            
            <!-- CARD SUPERIOR: CONFIGS E REPUTAÇÃO -->
            <div class="titan-card-premium flex flex-row items-stretch gap-12">
                
                <!-- Coluna Esquerda -->
                <div class="flex-1">
                    <h3 class="section-title text-center">Configurações</h3>
                    
                    <div class="input-container-premium">
                        <div class="icon-box"><i class="fa-solid fa-user-shield"></i></div>
                        <input type="text" class="input-premium-field" placeholder="Cargo Staff (ID)" name="staffRole" value="<%= settings.staffRole || '' %>">
                    </div>

                    <div class="input-container-premium">
                        <div class="icon-box"><i class="fa-solid fa-terminal"></i></div>
                        <input type="text" class="input-premium-field" placeholder="Canal de Logs (ID)" name="logChannel" value="<%= settings.logChannel || '' %>">
                    </div>
                </div>

                <!-- Divisória sutil -->
                <div class="w-[1px] bg-white/5 self-stretch"></div>

                <!-- Coluna Direita -->
                <div class="flex-[0.7] flex flex-col items-center justify-center">
                    <h3 class="section-title">Reputação por dia</h3>
                    <div class="input-container-premium w-full max-w-[250px]">
                        <div class="icon-box"><i class="fa-solid fa-star"></i></div>
                        <input type="number" class="input-premium-field" placeholder="0" name="dailyRep" value="<%= settings.dailyRep || 0 %>">
                    </div>
                </div>
            </div>

            <!-- CARD INFERIOR: PUNIÇÕES -->
            <div class="titan-card-premium flex flex-col items-center">
                <h3 class="section-title mb-10">Regras de Punição</h3>
                
                <div class="w-full max-w-[750px] flex flex-col gap-5">
                    <% [1, 2, 3, 4, 5].forEach((num) => { %>
                    <div class="flex items-center gap-10">
                        <span class="label-text w-[100px] uppercase">Nível <%= num %></span>
                        <div class="input-container-premium flex-1 !mb-0">
                            <input type="text" class="input-premium-field" 
                                   placeholder="-<%= num * 20 %> pts" 
                                   name="punish_level_<%= num %>"
                                   value="<%= settings['punish_level_' + num] || '' %>">
                        </div>
                    </div>
                    <% }) %>
                </div>

                <div class="mt-12">
                    <button type="submit" class="btn-salvar-final">
                        Salvar Alterações
                    </button>
                </div>
            </div>

        </form>

        <div class="text-center opacity-30 text-[10px] tracking-[6px] uppercase font-bold">
            BY: KNUST SEIER VI
        </div>

    </main>

</body>
</html>