<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações | Titan's Pass</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">
    <!-- Font Awesome para os ícones nos inputs -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --bg-main: #1F1D20;
            --bg-sidebar: #252326;
            --bg-card: #2A2A2A;
            --text-primary: #F8DCC0;
            --text-secondary: #A89986;
            --accent: #DCA15E;
            --surface: #803E30;
            --surface-hover: #4B2427;
            --stroke: #5A1811;
            --font-head: 'Tilt Warp', cursive;
            --font-body: 'Poppins', sans-serif;
        }

        body {
            font-family: var(--font-body);
            background-color: var(--bg-main);
            color: var(--text-primary);
            margin: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* SIDEBAR */
        .sidebar {
            width: 300px;
            background-color: var(--bg-sidebar);
            padding: 40px 20px;
            display: flex;
            flex-direction: column;
            border-right: 1px solid var(--stroke);
            box-shadow: 10px 0 30px rgba(0,0,0,0.3);
        }

        .logo-titans {
            width: 160px;
            margin: 0 auto 30px;
        }

        .nav-menu {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .nav-item {
            font-family: var(--font-head);
            text-decoration: none;
            color: var(--text-secondary);
            padding: 14px;
            border-radius: 12px;
            text-align: center;
            border: 1px solid var(--stroke);
            transition: 0.3s;
            text-transform: uppercase;
            font-size: 0.85rem;
        }

        .nav-item.active {
            background: var(--surface-hover);
            color: var(--text-primary);
            border-color: var(--accent);
        }

        /* ÁREA DE CONTEÚDO */
        .content {
            flex: 1;
            padding: 40px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 25px;
        }

        .header-meta {
            text-align: right;
            font-size: 0.65rem;
            color: var(--text-secondary);
            letter-spacing: 2px;
            margin-bottom: -15px;
        }

        /* SEÇÕES DE CONFIGURAÇÃO */
        .config-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }

        .config-card {
            background: var(--bg-card);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid rgba(255,255,255,0.05);
            box-shadow: 15px 15px 40px rgba(0,0,0,0.4);
        }

        .section-title {
            font-family: var(--font-head);
            text-align: center;
            text-transform: uppercase;
            color: var(--text-primary);
            margin-bottom: 25px;
            font-size: 1.2rem;
            letter-spacing: 1px;
        }

        /* ESTILO DOS INPUTS (IGUAL À FOTO) */
        .input-group {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            background: rgba(0,0,0,0.2);
            border-radius: 12px;
            border: 1px solid var(--stroke);
            overflow: hidden;
        }

        .input-icon {
            background: var(--accent);
            color: var(--bg-main);
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            font-size: 1.1rem;
        }

        .input-field {
            flex: 1;
            background: transparent;
            border: none;
            padding: 12px 15px;
            color: var(--text-secondary);
            font-family: var(--font-body);
            outline: none;
        }

        /* REGRAS DE PUNIÇÃO */
        .punishment-grid {
            display: flex;
            flex-direction: column;
            gap: 15px;
            max-width: 600px;
            margin: 0 auto;
        }

        .punishment-item {
            display: grid;
            grid-template-columns: 100px 1fr;
            align-items: center;
        }

        .level-label {
            font-size: 0.9rem;
            color: var(--text-secondary);
        }

        /* BOTÃO SALVAR */
        .save-container {
            text-align: center;
            margin-top: 20px;
        }

        .btn-save {
            font-family: var(--font-head);
            background: var(--bg-sidebar);
            color: var(--text-primary);
            border: 1px solid var(--stroke);
            padding: 12px 60px;
            border-radius: 12px;
            cursor: pointer;
            text-transform: uppercase;
            transition: 0.3s;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }

        .btn-save:hover {
            background: var(--surface);
            transform: scale(1.05);
        }
    </style>
</head>
<body>

    <aside class="sidebar">
        <img src="SUA_LOGO_AQUI" class="logo-titans">
        <nav class="nav-menu">
            <a href="/manage/<%= guild.id %>" class="nav-item active">Configurações</a>
            <a href="#" class="nav-item">Pot Server</a>
            <a href="#" class="nav-item">Tickets</a>
            <a href="#" class="nav-item">Staffs</a>
            <a href="#" class="nav-item">Strikes</a>
            <a href="#" class="nav-item">Perfil</a>
        </nav>
    </aside>

    <main class="content">
        <div class="header-meta">BY: KNUST SEIER VI</div>

        <form action="/manage/<%= guild.id %>/save" method="POST">
            
            <div class="config-row">
                <!-- COLUNA 1: CONFIGS GERAIS -->
                <div class="config-card">
                    <h3 class="section-title">Configurações</h3>
                    
                    <div class="input-group">
                        <div class="input-icon"><i class="fa-solid fa-user-shield"></i></div>
                        <input type="text" class="input-field" placeholder="Cargo Staff" name="staffRole">
                    </div>

                    <div class="input-group">
                        <div class="input-icon"><i class="fa-solid fa-terminal"></i></div>
                        <input type="text" class="input-field" placeholder="Canal de Logs" name="logChannel">
                    </div>
                </div>

                <!-- COLUNA 2: REPUTAÇÃO -->
                <div class="config-card">
                    <h3 class="section-title">Reputação por Dia</h3>
                    <div class="input-group">
                        <div class="input-icon"><i class="fa-solid fa-circle-user"></i></div>
                        <input type="number" class="input-field" placeholder="Número" name="dailyRep">
                    </div>
                </div>
            </div>

            <!-- REGRAS DE PUNIÇÃO (CARD LARGO) -->
            <div class="config-card" style="margin-top: 25px;">
                <h3 class="section-title">Regras de Punição</h3>
                
                <div class="punishment-grid">
                    <% [1, 2, 3, 4, 5].forEach(level => { %>
                    <div class="punishment-item">
                        <span class="level-label">Nível <%= level %></span>
                        <div class="input-group" style="margin-bottom: 0;">
                            <input type="text" class="input-field" placeholder="-<%= level * 20 %> pts" name="punish_level_<%= level %>">
                        </div>
                    </div>
                    <% }) %>
                </div>

                <div class="save-container">
                    <button type="submit" class="btn-save">Salvar</button>
                </div>
            </div>

        </form>
    </main>

</body>
</html>