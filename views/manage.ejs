<main class="flex-1 flex flex-col p-[30px] gap-[30px] overflow-y-auto">
    
    <div class="text-center opacity-40 text-[10px] tracking-[4px] mb-[-10px]">BY: KNUST SEIER VI</div>

    <form action="/manage/<%= guild.id %>/save" method="POST">
        
        <!-- CARD SUPERIOR: CONFIGS E REPUTAÇÃO -->
        <div class="titan-card-premium !flex-row !justify-between !items-start">
            
            <!-- Esquerda: Configurações -->
            <div class="flex-1 px-4">
                <h3 class="section-title text-center mb-6">Configurações</h3>
                
                <div class="input-container-premium">
                    <div class="icon-box"><i class="fa-solid fa-circle-user"></i></div>
                    <input type="text" class="input-premium-field" placeholder="Cargo Staff" name="staffRole">
                </div>

                <div class="input-container-premium">
                    <div class="icon-box"><i class="fa-solid fa-circle-user"></i></div>
                    <input type="text" class="input-premium-field" placeholder="Canal de logs" name="logChannel">
                </div>
            </div>

            <!-- Direita: Reputação -->
            <div class="flex-1 px-4">
                <h3 class="section-title text-center mb-6">Reputação por dia</h3>
                <div class="input-container-premium max-w-[300px] mx-auto">
                    <div class="icon-box"><i class="fa-solid fa-circle-user"></i></div>
                    <input type="number" class="input-premium-field" placeholder="Numero" name="dailyRep">
                </div>
            </div>
        </div>

        <!-- CARD INFERIOR: REGRAS DE PUNIÇÃO -->
        <div class="titan-card-premium flex-col items-center mt-6">
            <h3 class="section-title mb-10">Regras de Punição</h3>
            
            <div class="w-full max-w-[700px]">
                <% [1, 1, 1, 1, 1].forEach((val, index) => { %>
                <div class="level-row">
                    <span class="level-text">Nível 1</span>
                    <div class="input-container-premium flex-1 !mb-0">
                        <input type="text" class="input-premium-field" placeholder="-<%= (index + 1) * 20 - 10 %> pts" name="punish_level_<%= index + 1 %>">
                    </div>
                </div>
                <% }) %>
            </div>

            <div class="mt-8">
                <button type="submit" class="btn-salvar-final">Salvar</button>
            </div>
        </div>

    </form>
</main>