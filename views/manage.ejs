<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações | Titan's Pass</title>
    
    <!-- Fontes e Ícones -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Tailwind para utilitários rápidos -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Seu CSS Customizado (Certifique-se de que o caminho comece com /) -->
    <link rel="stylesheet" href="/css/style.css">

    <style>
        /* CSS INLINE PARA GARANTIR O FUNDO CASO O ARQUIVO EXTERNO DEMORE */
        body {
            background-color: #1F1D20 !important;
            margin: 0;
            padding: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }
    </style>
</head>

<body class="flex min-h-screen">

    <!-- Sidebar Lateral -->
    <%- include('partials/sidebar') %>

    <!-- Conteúdo Principal -->
    <main class="flex-1 w-full flex flex-col p-[30px] gap-[20px] overflow-y-auto bg-[#1F1D20]">
    
    <div class="text-center opacity-40 text-[10px] tracking-[4px] mb-[-10px] text-[#F8DCC0] uppercase">
        BY: KNUST SEIER VI
    </div>

    <form action="/manage/<%= guild.id %>/save" method="POST" class="flex flex-col gap-6">
        
        <!-- CARD SUPERIOR: CONFIGS E REPUTAÇÃO -->
        <div class="titan-card-premium flex flex-row justify-between items-stretch gap-10 min-h-[250px]">
            
            <!-- Coluna Esquerda: Configurações -->
            <div class="flex-1 flex flex-col justify-center">
                <h3 class="section-title text-center mb-6">Configurações</h3>
                
                <div class="input-container-premium">
                    <div class="icon-box"><i class="fa-solid fa-user-shield"></i></div>
                    <input type="text" class="input-premium-field" 
                           placeholder="Cargo Staff" name="staffRole" 
                           value="<%= settings.staffRole || '' %>">
                </div>

                <div class="input-container-premium">
                    <div class="icon-box"><i class="fa-solid fa-terminal"></i></div>
                    <input type="text" class="input-premium-field" 
                           placeholder="Canal de logs" name="logChannel" 
                           value="<%= settings.logChannel || '' %>">
                </div>
            </div>

            <!-- Divisor Vertical Visível -->
            <div class="w-[1px] bg-white/10 my-4"></div>

            <!-- Coluna Direita: Reputação -->
            <div class="flex-1 flex flex-col justify-center">
                <h3 class="section-title text-center mb-6">Reputação por dia</h3>
                <div class="input-container-premium max-w-[300px] mx-auto w-full">
                    <div class="icon-box"><i class="fa-solid fa-star"></i></div>
                    <input type="number" class="input-premium-field" 
                           placeholder="0" name="dailyRep" 
                           value="<%= settings.dailyRep || 0 %>">
                </div>
            </div>
        </div>

        <!-- CARD INFERIOR: REGRAS DE PUNIÇÃO -->
        <div class="titan-card-premium flex flex-col items-center p-10">
            <h3 class="section-title mb-10">Regras de Punição</h3>
            
            <div class="w-full max-w-[700px] flex flex-col gap-4">
                <% 
                const defaultPuns = { '1': '-20 pts', '2': '-40 pts', '3': '-60 pts', '4': '-80 pts', '5': '-100 pts' };
                [1, 2, 3, 4, 5].forEach((num) => { 
                %>
                <div class="flex items-center justify-between gap-10">
                    <span class="font-bold uppercase text-[0.75rem] tracking-[3px] text-[#F8DCC0] opacity-60 w-[100px]">
                        Nível <%= num %>
                    </span>
                    <div class="input-container-premium flex-1 !mb-0">
                        <input type="text" class="input-premium-field text-center" 
                               placeholder="<%= defaultPuns[num] %>" 
                               name="punish_level_<%= num %>"
                               value="<%= settings['punish_level_' + num] || '' %>">
                    </div>
                </div>
                <% }) %>
            </div>

            <div class="mt-12">
                <button type="submit" class="btn-salvar-final">
                    SALVAR ALTERAÇÕES
                </button>
            </div>
        </div>
    </form>
</main>

</body>
</html>