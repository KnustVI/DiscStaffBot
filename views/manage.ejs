<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configurações | Titan's Pass</title>
    
    <!-- Fontes e Ícones -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&family=Tilt+Warp&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Tailwind para utilitários rápidos -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Seu CSS Customizado (Certifique-se de que o caminho comece com /) -->
    <link rel="stylesheet" href="/css/style.css">

    <style>
        /* CSS INLINE PARA GARANTIR O FUNDO CASO O ARQUIVO EXTERNO DEMORE */
        body {
            background-color: #1F1D20 !important;
            margin: 0;
            padding: 0;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }
    </style>
</head>

<body class="flex min-h-screen">

    <!-- Sidebar Lateral -->
    <%- include('partials/sidebar') %>

    <!-- Conteúdo Principal -->
    <main class="flex-1 w-full flex flex-col p-[30px] gap-[20px] overflow-y-auto">
    
    <div class="text-center opacity-40 text-[10px] tracking-[4px] mb-[-10px] text-[#F8DCC0]">
        BY: KNUST SEIER VI
    </div>

    <form action="/manage/<%= guild.id %>/save" method="POST" class="flex flex-col gap-6">
        
        <!-- CARD SUPERIOR -->
        <div class="titan-card-premium flex flex-row justify-between items-start gap-10">
            <!-- Esquerda: Configurações -->
            <div class="flex-1 flex flex-col">
                <h3 class="section-title text-center mb-6">Configurações</h3>
                
                <div class="input-container-premium">
                    <div class="icon-box"><i class="fa-solid fa-user-shield"></i></div>
                    <input type="text" class="input-premium-field" placeholder="Cargo Staff" name="staffRole" value="<%= guild.staffRole || '' %>">
                </div>

                <div class="input-container-premium">
                    <div class="icon-box"><i class="fa-solid fa-terminal"></i></div>
                    <input type="text" class="input-premium-field" placeholder="Canal de logs" name="logChannel" value="<%= guild.logChannel || '' %>">
                </div>
            </div>

            <!-- Divisor Vertical (Opcional, mas ajuda no visual) -->
            <div class="w-[1px] h-full bg-white/5 self-stretch"></div>

            <!-- Direita: Reputação -->
            <div class="flex-1 flex flex-col">
                <h3 class="section-title text-center mb-6">Reputação por dia</h3>
                <div class="input-container-premium max-w-[350px] mx-auto w-full">
                    <div class="icon-box"><i class="fa-solid fa-star"></i></div>
                    <input type="number" class="input-premium-field" placeholder="0" name="dailyRep" value="<%= guild.dailyRep || 0 %>">
                </div>
            </div>
        </div>

        <!-- CARD INFERIOR: REGRAS DE PUNIÇÃO -->
        <div class="titan-card-premium flex-col items-center">
            <h3 class="section-title mb-10">Regras de Punição</h3>
            
            <div class="w-full max-w-[700px] flex flex-col gap-4">
                <% const punishments = [
                    { label: 'Nível 1', value: '-20 pts' },
                    { label: 'Nível 2', value: '-40 pts' },
                    { label: 'Nível 3', value: '-60 pts' },
                    { label: 'Nível 4', value: '-80 pts' },
                    { label: 'Nível 5', value: '-100 pts' }
                ]; %>

                <% punishments.forEach((p, index) => { %>
                <div class="flex items-center justify-between gap-10">
                    <span class="font-bold uppercase text-[0.8rem] tracking-widest text-[#F8DCC0] opacity-80 min-w-[80px]">
                        <%= p.label %>
                    </span>
                    <div class="input-container-premium flex-1 !mb-0">
                        <input type="text" class="input-premium-field" placeholder="<%= p.value %>" name="punish_level_<%= index + 1 %>">
                    </div>
                </div>
                <% }) %>
            </div>

            <div class="mt-10">
                <button type="submit" class="btn-salvar-final">Salvar Alterações</button>
            </div>
        </div>
    </form>
</main>

</body>
</html>